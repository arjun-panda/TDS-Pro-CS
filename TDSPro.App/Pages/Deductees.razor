@page "/deductees"
@inject AppStateService AppState
@inject DeducteeService Svc
@inject TdsRulesService RulesSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">Deductee Master</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenAdd">Add Deductee</MudButton>
</div>

<div style="height:calc(100vh - 200px);overflow:hidden">
<MudDataGrid T="Deductee" Items="_items" Hover="true" Striped="true" Dense="true"
             QuickFilter="_filter" SortMode="SortMode.Multiple"
             FixedHeader="true" Height="calc(100vh - 200px)">
    <ToolBarContent>
        <MudTextField @bind-Value="_search" Placeholder="Search name / PAN / section..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Class="mt-0" Style="max-width:340px" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.DeducteeCode" Title="Code" />
        <PropertyColumn Property="x => x.Name"         Title="Name" />
        <PropertyColumn Property="x => x.Pan"          Title="PAN" />
        <PropertyColumn Property="x => x.Section"      Title="Section" />
        <PropertyColumn Property="x => x.DeducteeType" Title="Type" />
        <PropertyColumn Property="x => x.Rate"         Title="Rate %" Format="N2" />
        <TemplateColumn Title="PAN Status" Sortable="false">
            <CellTemplate>
                @if (context.Item.PanVerified)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Verified</MudChip>
                }
                else if (!string.IsNullOrEmpty(context.Item.PanVerificationStatus))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">@context.Item.PanVerificationStatus</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Unverified</MudChip>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="LDC" Sortable="false">
            <CellTemplate>
                @if (!string.IsNullOrEmpty(context.Item.LowerCertNo))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info"
                             Icon="@Icons.Material.Filled.VerifiedUser">
                        @context.Item.LowerCertRate.ToString("N1")%
                    </MudChip>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Actions" Sortable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"   Size="Size.Small" OnClick="() => OpenEdit(context.Item)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteItem(context.Item)" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>
</div>

<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
        @(_editing?.Id == 0 ? "Add" : "Edit") Deductee
    </TitleContent>
    <DialogContent>
        @if (_editing != null)
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-3">

                @* ── Basic Details ── *@
                <MudTabPanel Text="Basic Details" Icon="@Icons.Material.Filled.Info">
                    <MudGrid>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="_editing.DeducteeCode" Label="Deductee Code"
                                          Variant="Variant.Outlined" Placeholder="Auto if blank" />
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="_editing.Name" Label="Full Name*" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="6">
                            <PanField Value="@_editing.Pan" Label="PAN*"
                                      ValueChanged="@((v) => { _editing.Pan = v; })"
                                      TypeChanged="@((t) => { _editing.DeducteeType = t; FetchDefaultRate(); })"
                                      ValidChanged="@((ok) => _panError = !ok)" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Value="_editing.DeducteeType" Label="Deductee Type"
                                       Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                                       ValueChanged="@((string v) => { _editing.DeducteeType = v; FetchDefaultRate(); })">
                                @foreach (var t in AppConstants.DeducteeTypes)
                                { <MudSelectItem Value="@t">@t</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Value="_editing.Section" Label="Default Section"
                                       Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                                       ValueChanged="@((string v) => { _editing.Section = v; FetchDefaultRate(); })">
                                @foreach (var s in AppConstants.KnownSections)
                                { <MudSelectItem Value="@s">@s</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="3">
                            <MudNumericField @bind-Value="_editing.Rate" Label="TDS Rate %"
                                             Variant="Variant.Outlined" Format="N2" HideSpinButtons="true" Class="amount-field"
                                             HelperText="Auto-fetched from rules" />
                        </MudItem>
                        <MudItem xs="3" Class="d-flex align-center">
                            <MudCheckBox @bind-Value="_editing.IsResident" Label="Resident Indian" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_editing.Remarks" Label="Remarks" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* ── Lower Deduction Certificate ── *@
                <MudTabPanel Text="LDC / Exemption" Icon="@Icons.Material.Filled.VerifiedUser">
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        Lower Deduction Certificate (u/s 197) allows reduced TDS rate.
                        Certificate must be obtained from jurisdictional AO.
                    </MudAlert>
                    <MudGrid>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.LowerCertNo" Label="Certificate No."
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="3">
                            <MudNumericField @bind-Value="_editing.LowerCertRate" Label="Lower Rate %"
                                             Variant="Variant.Outlined" Format="N2" HideSpinButtons="true" Class="amount-field"
                                             HelperText="Rate as per certificate" />
                        </MudItem>
                        <MudItem xs="3">
                            <MudTextField @bind-Value="_editing.LowerCertTill" Label="Valid Till"
                                          Variant="Variant.Outlined" Placeholder="31-03-2027" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                Section 206AA: If PAN not provided, TDS @@20% (higher of prescribed rate or 20%).
                                Section 206AB: If ITR not filed for 2 preceding years and TDS > ₹50,000, rate is higher of 5% or twice normal rate.
                            </MudAlert>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* ── PAN Verification ── *@
                <MudTabPanel Text="PAN Verification" Icon="@Icons.Material.Filled.FactCheck">
                    <MudGrid>
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2">PAN: @(_editing.Pan ?? "—")</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Status: @(string.IsNullOrEmpty(_editing.PanVerificationStatus) ? "Not checked" : _editing.PanVerificationStatus)
                            </MudText>
                        </MudItem>
                        <MudItem xs="6">
                            @if (_editing.PanVerified)
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.Verified" Color="Color.Success">
                                    Verified — @_editing.PanVerifiedName
                                </MudChip>
                            }
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Last checked: @(string.IsNullOrEmpty(_editing.PanVerifiedAt) ? "Never" : _editing.PanVerifiedAt)
                            </MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true">
                                PAN verification via TRACES requires active portal login.
                                Use the Portals page to configure TRACES credentials.
                            </MudAlert>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

            </MudTabs>

            @if (!string.IsNullOrEmpty(_saveError))
            { <MudAlert Severity="Severity.Error" Class="mt-2">@_saveError</MudAlert> }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Deductee> _items = new();
    private string _search = "";
    private bool _dialogOpen;
    private Deductee? _editing;
    private string _saveError = "";
    private bool _panError = false;
    private DialogOptions _dialogOptions = new()
        { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };

    private Func<Deductee, bool> _filter =>
        d => string.IsNullOrEmpty(_search) ||
             d.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             d.Pan.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             d.Section.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (d.DeducteeCode?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    protected override void OnInitialized() => Load();
    void Load() => _items = Svc.GetAll();

    void OpenAdd()
    {
        _editing = new Deductee { IsResident = true, DeducteeType = "Individual", Section = "194J" };
        _saveError = ""; _panError = false;
        _dialogOpen = true;
    }

    void OpenEdit(Deductee d)
    {
        _editing = new Deductee
        {
            Id = d.Id, DeducteeCode = d.DeducteeCode, Name = d.Name, Pan = d.Pan,
            Section = d.Section, DeducteeType = d.DeducteeType, Rate = d.Rate,
            IsResident = d.IsResident, Remarks = d.Remarks,
            LowerCertNo = d.LowerCertNo, LowerCertRate = d.LowerCertRate, LowerCertTill = d.LowerCertTill,
            PanVerified = d.PanVerified, PanVerificationStatus = d.PanVerificationStatus,
            PanVerifiedName = d.PanVerifiedName, PanVerifiedAt = d.PanVerifiedAt
        };
        _saveError = ""; _panError = false;
        _dialogOpen = true;
    }

    void FetchDefaultRate()
    {
        if (_editing == null || string.IsNullOrEmpty(_editing.Section)) return;
        var rate = Svc.GetDefaultRate(_editing.Section, _editing.DeducteeType);
        if (rate > 0) _editing.Rate = rate;
    }

    void Save()
    {
        if (_editing == null) return;
        if (string.IsNullOrWhiteSpace(_editing.Name)) { _saveError = "Name is required."; return; }
        if (!string.IsNullOrWhiteSpace(_editing.Pan))
        {
            _editing.Pan = _editing.Pan.Trim().ToUpper();
            if (!Validators.IsValidPan(_editing.Pan))
                { _saveError = "Invalid PAN format (e.g. ABCDE1234F)."; return; }
        }
        // Auto-rate from default rule if rate not set
        if (_editing.Rate == 0 && !string.IsNullOrEmpty(_editing.Section))
            _editing.Rate = Svc.GetDefaultRate(_editing.Section, _editing.DeducteeType);

        var (ok, msg) = Svc.Save(_editing);
        if (ok) { _dialogOpen = false; Load(); Snackbar.Add("Deductee saved.", Severity.Success); }
        else _saveError = msg;
    }

    async Task DeleteItem(Deductee d)
    {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Deductee?",
            $"Delete '{d.Name}' (PAN: {d.Pan})? All TDS entries for this deductee will be affected.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        var (ok, msg) = Svc.Delete(d.Id);
        if (ok) { Load(); Snackbar.Add("Deleted.", Severity.Success); }
        else Snackbar.Add(msg, Severity.Error);
    }
}

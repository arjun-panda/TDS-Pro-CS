@page "/deductors"
@inject AppStateService AppState
@inject DeductorService Svc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">Deductors</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAdd">Add Deductor</MudButton>
</div>

<div style="height:calc(100vh - 200px);overflow:hidden">
<MudDataGrid T="Deductor" Items="_items" Hover="true" Striped="true" Dense="true"
             QuickFilter="_filter" SortMode="SortMode.Multiple"
             FixedHeader="true" Height="calc(100vh - 200px)">
    <ToolBarContent>
        <MudTextField @bind-Value="_search" Placeholder="Search name / TAN / PAN..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Class="mt-0" Style="max-width:320px" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.CompanyName" Title="Company Name" />
        <PropertyColumn Property="x => x.Tan"         Title="TAN" />
        <PropertyColumn Property="x => x.Pan"         Title="PAN" />
        <PropertyColumn Property="x => x.City"        Title="City" />
        <PropertyColumn Property="x => x.State"       Title="State" />
        <PropertyColumn Property="x => x.ContactPerson" Title="Contact" />
        <TemplateColumn Title="Active" Sortable="false">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                    @(context.Item.IsActive ? "Active" : "Inactive")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Actions" Sortable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="() => OpenEdit(context.Item)" />
                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="() => SelectDeductor(context.Item)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error" OnClick="@(() => DeleteItem(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>
</div>

<!-- Add/Edit Dialog -->
<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
        @(_editing?.Id == 0 ? "Add New" : "Edit") Deductor
    </TitleContent>
    <DialogContent>
        @if (_editing != null)
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-3">

                @* ── Basic Info ── *@
                <MudTabPanel Text="Basic Info" Icon="@Icons.Material.Filled.Info">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_editing.CompanyName" Label="Company / Deductor Name*"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="6">
                            <TanField Value="@_editing.Tan" Label="TAN*"
                                      ValueChanged="@((v) => _editing.Tan = v)" />
                        </MudItem>
                        <MudItem xs="6">
                            <PanField Value="@_editing.Pan" Label="PAN*" ShowType="false"
                                      ValueChanged="@((v) => _editing.Pan = v)" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_editing.Address" Label="Address" Variant="Variant.Outlined" Lines="2" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.City" Label="City" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.Pincode" Label="Pincode" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect @bind-Value="_editing.State" Label="State" Variant="Variant.Outlined"
                                       AnchorOrigin="Origin.BottomCenter">
                                @foreach (var s in AppConstants.IndianStates)
                                { <MudSelectItem Value="@s">@s</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="_editing.IsActive" Label="Active Deductor" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* ── Contact Details ── *@
                <MudTabPanel Text="Contact" Icon="@Icons.Material.Filled.ContactPhone">
                    <MudGrid>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.ContactPerson" Label="Contact Person" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.Phone" Label="Phone" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Value="@_editing.Email" Label="Email" Variant="Variant.Outlined"
                                          InputType="InputType.Email"
                                          Style="text-transform:lowercase"
                                          Immediate="true" ValueChanged="@((string v) => _editing.Email = (v ?? "").Trim().ToLower())" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Contact person details appear on return filing forms (26Q/27Q) as the responsible person.
                            </MudAlert>
                        </MudItem>
                        <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Bank Defaults (auto-filled in Challans)</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.DefaultBsrCode" Label="BSR Code (7 digits)" Variant="Variant.Outlined"
                                          HelperText="Same for all challans from this bank branch" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_editing.DefaultBankName" Label="Bank Name" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* ── Portal Credentials ── *@
                <MudTabPanel Text="Portal Credentials" Icon="@Icons.Material.Filled.Lock">
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        Passwords stored encrypted. TAN is TRACES login ID; PAN is IT Portal login ID.
                    </MudAlert>
                    <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1">TRACES (tdscpc.gov.in)</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_cpcPass" Label="TRACES Password"
                                          InputType="@(_showCpc ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showCpc ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="() => _showCpc = !_showCpc"
                                          HelperText="@("Login ID = TAN (" + (_editing?.Tan ?? "") + ")")" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1 mt-2">IT Portal (incometax.gov.in)</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_itPass" Label="IT Portal Password"
                                          InputType="@(_showIt ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showIt ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="() => _showIt = !_showIt"
                                          HelperText="@("Login ID = PAN (" + (_editing?.Pan ?? "") + ")")" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

            </MudTabs>

            @if (!string.IsNullOrEmpty(_saveError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_saveError</MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Deductor> _items = new();
    private string _search = "";
    private bool _dialogOpen;
    private Deductor? _editing;
    private string _saveError = "";
    private string _cpcPass = "", _itPass = "";
    private bool _showCpc, _showIt;
    private DialogOptions _dialogOptions = new()
        { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };

    private Func<Deductor, bool> _filter =>
        d => string.IsNullOrEmpty(_search) ||
             d.CompanyName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             d.Tan.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (d.Pan?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    protected override void OnInitialized() => Load();
    void Load() => _items = Svc.GetAll();

    void OpenAdd()
    {
        _editing = new Deductor { FinancialYear = AppState.CurrentFY, IsActive = true, State = "Delhi" };
        _cpcPass = _itPass = _saveError = "";
        _dialogOpen = true;
    }

    void OpenEdit(Deductor d)
    {
        _editing = new Deductor
        {
            Id = d.Id, CompanyName = d.CompanyName, Tan = d.Tan, Pan = d.Pan,
            Address = d.Address, City = d.City, State = d.State, Pincode = d.Pincode,
            ContactPerson = d.ContactPerson, Phone = d.Phone, Email = d.Email,
            FinancialYear = d.FinancialYear, IsActive = d.IsActive,
            CpcPassword = d.CpcPassword, ItPassword = d.ItPassword,
            DefaultBsrCode = d.DefaultBsrCode, DefaultBankName = d.DefaultBankName
        };
        _cpcPass = _itPass = _saveError = "";
        _dialogOpen = true;
    }

    void Save()
    {
        if (_editing == null) return;

        // License limit — only block when adding new deductor
        if (_editing.Id == 0)
        {
            if (AppState.CurrentLicense.IsReadOnly)
                { Snackbar.Add("License expired — renew to add deductors.", Severity.Warning); return; }
            if (_items.Count >= AppState.CurrentLicense.MaxDeductors)
                { Snackbar.Add($"Limit reached: your license allows {AppState.CurrentLicense.MaxDeductors} deductor(s). Upgrade to Pro for more.", Severity.Warning); return; }
        }

        if (string.IsNullOrWhiteSpace(_editing.CompanyName)) { _saveError = "Company name is required."; return; }
        if (string.IsNullOrWhiteSpace(_editing.Tan))         { _saveError = "TAN is required."; return; }

        _editing.Tan = _editing.Tan.Trim().ToUpper();
        if (!Validators.IsValidTan(_editing.Tan)) { _saveError = "Invalid TAN format (e.g. ABCD12345E)."; return; }

        if (!string.IsNullOrWhiteSpace(_editing.Pan))
        {
            _editing.Pan = _editing.Pan.Trim().ToUpper();
            if (!Validators.IsValidPan(_editing.Pan)) { _saveError = "Invalid PAN format (e.g. ABCDE1234F)."; return; }
        }

        // Store portal passwords if entered — save to both DB column and AES credential store
        if (!string.IsNullOrEmpty(_cpcPass))
        {
            _editing.CpcPassword = Database.HashPassword(_cpcPass);
            TDSPro.DAL.AesEncryption.SaveCredential("TracesPassword", _cpcPass);
        }
        if (!string.IsNullOrEmpty(_itPass))
        {
            _editing.ItPassword = Database.HashPassword(_itPass);
            TDSPro.DAL.AesEncryption.SaveCredential("ItPortalPassword", _itPass);
        }

        var (ok, msg) = Svc.Save(_editing);
        if (ok)
        {
            _dialogOpen = false;
            Load();
            Snackbar.Add("Deductor saved.", Severity.Success);
        }
        else _saveError = msg;
    }

    void SelectDeductor(Deductor d)
    {
        AppState.SetDeductor(d.Id, d.CompanyName, d.Tan);
        Snackbar.Add($"Active company: {d.CompanyName}", Severity.Info);
    }

    async Task DeleteItem(Deductor d)
    {
        var ok = await DialogSvc.ShowMessageBox(
            "Delete Company?",
            $"Delete '{d.CompanyName}'? All related TDS entries and challans will also be removed.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        var (success, msg) = Svc.Delete(d.Id);
        if (success) { Load(); Snackbar.Add("Deleted.", Severity.Success); }
        else Snackbar.Add(msg, Severity.Error);
    }
}

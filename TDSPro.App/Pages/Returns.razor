@page "/returns"
@using System.IO
@using TDSPro.Common
@inject AppStateService AppState
@inject ReturnService Svc
@inject DeductorService DeductorSvc
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">Returns / FVU — FY @AppState.CurrentFY</MudText>
    <MudSpacer />
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        @TaxRules.ActName(AppState.CurrentFY) &nbsp;·&nbsp; AY @TaxRules.AssessmentYearLabel(AppState.CurrentFY)
    </MudText>
</div>

@* ── Info banner ── *@
<MudPaper Class="pa-3 mb-4 d-flex gap-4 flex-wrap" Elevation="0"
          Style="background:#e3f2fd;border-radius:10px;border-left:4px solid #1565C0">
    <div><span style="font-size:10px;color:#666">Salary TDS Section</span><br/><b>@TaxRules.SalaryTdsSection(AppState.CurrentFY)</b></div>
    <div><span style="font-size:10px;color:#666">Salary Return Form</span><br/><b>@TaxRules.SalaryReturnForm(AppState.CurrentFY)</b></div>
    <div><span style="font-size:10px;color:#666">Non-Salary Section</span><br/><b>@TaxRules.NonSalaryTdsSection(AppState.CurrentFY)</b></div>
    <div><span style="font-size:10px;color:#666">Non-Salary Return Form</span><br/><b>@TaxRules.NonSalaryReturnForm(AppState.CurrentFY)</b></div>
    <div><span style="font-size:10px;color:#666">TDS Certificate</span><br/><b>@TaxRules.NonSalaryTdsCertForm(AppState.CurrentFY)</b></div>
</MudPaper>

<MudGrid Spacing="3">
    @* ── LEFT: Generate + Validate ── *@
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="1" Style="border-radius:10px">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Generate &amp; Validate FVU</MudText>

            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudSelect @bind-Value="_formType" Label="Form Type" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var f in AppConstants.ReturnFormTypes)
                        { <MudSelectItem Value="@f">@f</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect @bind-Value="_quarter" Label="Quarter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var q in AppConstants.QuarterCodes)
                        { <MudSelectItem Value="@q">@q</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_isCorrection" Label="Correction Return (C1/C2/C3)" Dense="true" />
                </MudItem>
                @if (_isCorrection)
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_prevPrn" Label="Previous PRN*" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      HelperText="Provisional Receipt Number from the original return" />
                    </MudItem>
                }
                <MudItem xs="12"><MudDivider Class="my-1" /></MudItem>
                <MudItem xs="5">
                    <MudTextField @bind-Value="_responsibleName" Label="Responsible Person*" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  HelperText="As appearing on PAN card" />
                </MudItem>
                <MudItem xs="4">
                    <PanField Value="@_responsiblePan" Label="PAN of Responsible*" ShowType="false"
                              ValueChanged="@((v) => _responsiblePan = v)" />
                </MudItem>
                <MudItem xs="3">
                    <MudTextField @bind-Value="_designation" Label="Designation" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                @* ── Action Buttons ── *@
                <MudItem xs="12" Class="d-flex gap-2 flex-wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               OnClick="GenerateTxtOnly" Disabled="_generating" Size="Size.Small">
                        @if (_generating && _step == Step.GeneratingTxt) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Generate .txt
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.VerifiedUser"
                               OnClick="GenerateAndValidate" Disabled="_generating || !_fvuReady" Size="Size.Small">
                        @if (_generating && _step == Step.RunningFvu) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Generate &amp; Validate (FVU)
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Print"
                               OnClick="GeneratePaperReturn" Disabled="_generating" Size="Size.Small">
                        @if (_generating && _step == Step.PaperReturn) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Paper Return
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Article"
                               OnClick="() => _nilDialogOpen = true" Size="Size.Small">
                        NIL Return
                    </MudButton>
                </MudItem>

                @* ── FVU readiness indicator ── *@
                @if (!_fvuReady)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.Settings">
                            FVU validation unavailable — @_fvuNotReadyReason.
                            <MudLink Href="/settings" Style="font-weight:600;margin-left:4px">Configure in Settings →</MudLink>
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>

            @* ── Progress log ── *@
            @if (_logLines.Count > 0)
            {
                <div style="background:#1e1e2e;color:#cdd6f4;border-radius:6px;padding:10px 14px;margin-top:14px;
                            font-family:monospace;font-size:11px;max-height:130px;overflow-y:auto;line-height:1.6">
                    @foreach (var line in _logLines)
                    {
                        <div>@line</div>
                    }
                </div>
            }

            @* ── Result banner ── *@
            @if (!string.IsNullOrEmpty(_result))
            {
                <MudAlert Severity="@_resultSeverity" Class="mt-3" Style="white-space:pre-line">@_result</MudAlert>
                <div class="d-flex gap-2 mt-2 flex-wrap">
                    @if (!string.IsNullOrEmpty(_lastTxtPath))
                    {
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.FolderOpen"
                                   OnClick="() => OpenFolder(_lastTxtPath)">Open .txt Folder</MudButton>
                    }
                    @if (!string.IsNullOrEmpty(_lastFvuPath))
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="() => OpenFolder(_lastFvuPath)">Open .fvu File Folder</MudButton>
                    }
                    @if (!string.IsNullOrEmpty(_lastZipPath))
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.FolderZip"
                                   OnClick="() => OpenFolder(_lastZipPath)">Open Zip (Upload This)</MudButton>
                    }
                    @if (!string.IsNullOrEmpty(_errorHtmlPath))
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.BugReport"
                                   OnClick="OpenErrorReport">View Error Report</MudButton>
                    }
                </div>
            }

            @* ── FVU Error Table ── *@
            @if (_fvuErrors.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1" Color="Color.Error">
                    FVU Validation Errors (@_fvuErrors.Count)
                </MudText>
                <MudSimpleTable Dense="true" Bordered="true" Style="font-size:12px">
                    <thead>
                        <tr style="background:#ffebee">
                            <th style="width:90px">Code</th>
                            <th>What to Fix</th>
                            <th style="color:#888;font-weight:400">NSDL Detail</th>
                            <th style="width:80px">Record</th>
                            <th style="width:60px">Seq</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _fvuErrors)
                        {
                            var desc = e.Description ?? "";
                            var bracketIdx = desc.LastIndexOf('[');
                            var friendly = bracketIdx > 0 ? desc[..bracketIdx].Trim() : desc;
                            var raw = bracketIdx > 0 ? desc[(bracketIdx + 1)..].TrimEnd(']') : "";
                            <tr>
                                <td style="font-weight:600;color:#c62828;white-space:nowrap">@e.Code</td>
                                <td style="color:#1e3a8a;font-weight:600">@friendly</td>
                                <td style="color:#6b7280;font-size:10px">@raw</td>
                                <td>@e.RecordType</td>
                                <td>@e.SeqNo</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>

        @* ── Portal & Download Cards ── *@
        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Downloads &amp; Portals</MudText>
        <MudGrid Spacing="2">
            @foreach (var card in _portalCards)
            {
                <MudItem xs="6" sm="4">
                    <MudPaper Class="pa-3" Elevation="1"
                              Style="@CardStyle(card.Color)" @onclick="() => OpenPortalCard(card)">
                        <div style="@CardTextStyle(card.Color)">@card.Title</div>
                        <div style="font-size:10px;color:#888;margin-top:2px">@card.Sub</div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudItem>

    @* ── RIGHT: 8-Step Guide ── *@
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1" Style="border-radius:10px">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Return Filing — Step by Step</MudText>
            @foreach (var (step, i) in _steps.Select((s, i) => (s, i + 1)))
            {
                <div class="d-flex gap-3 mb-3"
                     style="@(i == _activeStep ? "background:#e3f2fd;border-radius:6px;padding:4px 6px" : "")">
                    <div style="min-width:28px;height:28px;border-radius:50%;
                                background:@(i <= _activeStep ? "#1565C0" : "#bbb");color:#fff;
                                display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">
                        @if (i < _activeStep) { <span>✓</span> } else { @i }
                    </div>
                    <div>
                        <div style="font-size:13px;font-weight:600">@step.Title</div>
                        <div style="font-size:11px;color:#666">@step.Detail</div>
                    </div>
                </div>
            }
        </MudPaper>

        @* ── Quick Status ── *@
        <MudPaper Class="pa-3 mt-3" Elevation="1" Style="border-radius:10px">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Filing Status — @_quarter @AppState.CurrentFY</MudText>
            <div class="d-flex flex-column gap-1" style="font-size:12px">
                <div class="d-flex justify-space-between">
                    <span style="color:#555">Challans (Paid)</span>
                    <b>@_statusChallanCount</b>
                </div>
                <div class="d-flex justify-space-between">
                    <span style="color:#555">Entries (Paid)</span>
                    <b>@_statusEntryCount</b>
                </div>
                <div class="d-flex justify-space-between">
                    <span style="color:#555">Linked to Challan</span>
                    <b style="color:@(_statusLinkedCount == _statusEntryCount && _statusEntryCount > 0 ? "#2e7d32" : "#e65100")">
                        @_statusLinkedCount / @_statusEntryCount
                    </b>
                </div>
                <div class="d-flex justify-space-between">
                    <span style="color:#555">Java</span>
                    <b style="color:@(_fvuJavaOk?"#2e7d32":"#e65100")">@(_fvuJavaOk?"✅ Ready":"⚠ Not found")</b>
                </div>
                <div class="d-flex justify-space-between">
                    <span style="color:#555">FVU Jar</span>
                    <b style="color:@(_fvuJarOk?"#2e7d32":"#e65100")">@(_fvuJarOk?"✅ Ready":"⚠ Not found")</b>
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@* ── NIL Return Dialog ── *@
<MudDialog @bind-Visible="_nilDialogOpen" Options='new DialogOptions { MaxWidth=MaxWidth.Small, FullWidth=true }'>
    <TitleContent>Generate NIL Return</TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            NIL returns must be filed even when no TDS was deducted in a quarter.
        </MudAlert>
        <MudGrid>
            <MudItem xs="6">
                <MudSelect @bind-Value="_nilForm" Label="Form Type" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var f in AppConstants.ReturnFormTypes)
                    { <MudSelectItem Value="@f">@f</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudSelect @bind-Value="_nilQuarter" Label="Quarter" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var q in AppConstants.QuarterCodes)
                    { <MudSelectItem Value="@q">@q</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_nilName" Label="Responsible Person*" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <PanField Value="@_nilPan" Label="PAN*" ShowType="false"
                          ValueChanged="@((v) => _nilPan = v)" />
            </MudItem>
        </MudGrid>
        @if (!string.IsNullOrEmpty(_nilResult))
        { <MudAlert Severity="@_nilSeverity" Class="mt-2">@_nilResult</MudAlert> }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _nilDialogOpen = false">Close</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="GenerateNil" Disabled="_generating">
            @if (_generating) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Generate NIL File
        </MudButton>
    </DialogActions>
</MudDialog>

@* ── Portal Launch Dialog ── *@
<MudDialog @bind-Visible="_launchOpen" Options='new DialogOptions { MaxWidth=MaxWidth.ExtraSmall, FullWidth=true }'>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.OpenInBrowser" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@_launchTitle</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            @* User ID row *@
            <MudItem xs="12">
                <div style="background:#e3f2fd;border-radius:8px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between">
                    <div>
                        <div style="font-size:10px;color:#666;margin-bottom:2px">User ID (TAN / PAN)</div>
                        <div style="font-size:16px;font-weight:700;font-family:monospace;color:#1565C0;letter-spacing:2px">@_launchUser</div>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                   OnClick="@(() => CopyText(_launchUser))" />
                </div>
            </MudItem>

            @* Password row *@
            @if (!string.IsNullOrEmpty(_launchPass))
            {
                <MudItem xs="12">
                    <div style="background:#e8f5e9;border-radius:8px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between">
                        <div>
                            <div style="font-size:10px;color:#666;margin-bottom:2px">Password</div>
                            <div style="font-size:22px;font-weight:700;font-family:monospace;color:#2e7d32;letter-spacing:4px">@_launchPass</div>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                       OnClick="@(() => CopyText(_launchPass))" />
                    </div>
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Password not saved. Go to <b>Deductors → Portal Credentials tab</b> → enter and save password.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _launchOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.OpenInBrowser"
                   OnClick="LaunchConfirm">Open Browser</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private enum Step { Idle, GeneratingTxt, RunningFvu, PaperReturn }

    private string _formType        = "26Q";
    private string _quarter         = "Q1";
    private bool   _isCorrection    = false;
    private string _prevPrn         = "";
    private string _responsibleName = "";
    private string _responsiblePan  = "";
    private string _designation     = "Director";
    private bool   _generating;
    private Step   _step = Step.Idle;

    private string   _result          = "";
    private string   _lastTxtPath     = "";
    private string   _lastFvuPath     = "";
    private string   _lastZipPath     = "";
    private string   _errorHtmlPath   = "";
    private Severity _resultSeverity  = Severity.Info;
    private List<TDSPro.DAL.FvuError> _fvuErrors = new();
    private List<string> _logLines = new();

    // FVU readiness
    private bool   _fvuReady         = false;
    private bool   _fvuJavaOk        = false;
    private bool   _fvuJarOk         = false;
    private string _fvuNotReadyReason = "";

    // Quick status
    private int _statusChallanCount = 0;
    private int _statusEntryCount   = 0;
    private int _statusLinkedCount  = 0;
    private int _activeStep         = 3; // default: step 3 = Generate

    // NIL return
    private bool     _nilDialogOpen = false;
    private string   _nilForm     = "26Q";
    private string   _nilQuarter  = "Q1";
    private string   _nilName     = "";
    private string   _nilPan      = "";
    private string   _nilResult   = "";
    private Severity _nilSeverity = Severity.Info;

    private record PortalCard(string Title, string Sub, string Url, string Color, string CredUser = "", string CredKey = "");
    private record FilingStep(string Title, string Detail);

    private List<PortalCard> _portalCards = new();

    void BuildPortalCards()
    {
        var tracesUser = Database.GetSetting("TracesTan", AppState.CurrentDeductorTan);
        var itUser     = Database.GetSetting("ItPortalUserId", "");
        var tinUser    = Database.GetSetting("TinNsdlTan", AppState.CurrentDeductorTan);
        _portalCards = new()
        {
            new("RPU + FVU",     "Download from Protean (NSDL)",  "https://www.protean-tinpan.com/services/etds-etcs/fvu.html", "#1565C0"),
            new("IT Portal",     "File return — incometax.gov.in","https://eportal.incometax.gov.in/iec/foservices/#/login",    "#2e7d32", itUser,     "ItPortalPassword"),
            new("TRACES",        "Download certs, check status",  "https://traces.tdscpc.gov.in/auth/login/loginScreen",                  "#6a1b9a", tracesUser, "TracesPassword"),
            new("OLTAS / CSI",   "Download CSI challan file",     "https://eportal.incometax.gov.in/iec/foservices/#/login",    "#e65100"),
            new("TIN-NSDL",      "Challan payment, e-TDS",        "https://onlineservices.tin.egov-nsdl.com/etaxnew/tdsnontds.jsp", "#0277bd", tinUser, "TinNsdlPassword"),
            new("Java Download", "Required for FVU",              "https://www.java.com/download/",                             "#795548"),
        };
    }

    private readonly List<FilingStep> _steps = new()
    {
        new("Add Challans",         "Enter Challan 281 payments in the Challans module."),
        new("Add TDS Entries",      "Record all TDS deductions against deductees with correct sections."),
        new("Generate .txt File",   "Generate the return text file using this wizard."),
        new("Validate with FVU",    "Run NSDL FVU — validates PAN, challan totals, section codes."),
        new("Download CSI File",    "From OLTAS → e-Pay Tax → Payment History for the quarter."),
        new("Upload to IT Portal",  "Login incometax.gov.in with TAN, upload validated .fvu file."),
        new("Download TDS Cert",    "Download Form 16A / 16 from TRACES and issue to deductees."),
    };

    protected override void OnInitialized()
    {
        _quarter = CurrentAutoQuarter();
        CheckFvuReadiness();
        LoadQuickStatus();
        BuildPortalCards();
        try
        {
            var d = DeductorSvc.GetAll().FirstOrDefault(x => x.Id == AppState.CurrentDeductorId);
            if (d != null)
            {
                _responsibleName = d.ContactPerson;
                _responsiblePan  = d.Pan;
                _nilName         = d.ContactPerson;
                _nilPan          = d.Pan;
            }
        }
        catch { }
    }

    // ── Check Java + FVU jar are configured ────────────────────────────────────
    void CheckFvuReadiness()
    {
        try
        {
            var preflight = Svc.CheckFvuPreflight();
            _fvuReady = preflight.IsReady;
            _fvuNotReadyReason = preflight.IsReady
                ? ""
                : string.Join(" | ", preflight.Issues);
            // Update individual status flags for UI indicators
            var javaPath = Database.GetSetting("JavaPath", "");
            var fvuPath  = Database.GetSetting("FvuPath",  "");
            _fvuJavaOk = !string.IsNullOrEmpty(javaPath) && File.Exists(javaPath);
            _fvuJarOk  = !string.IsNullOrEmpty(fvuPath)  && File.Exists(fvuPath);
        }
        catch { _fvuReady = false; _fvuNotReadyReason = "Cannot read settings"; }
    }

    // ── Load quick filing status for current quarter ────────────────────────
    void LoadQuickStatus()
    {
        if (AppState.CurrentDeductorId == 0) return;
        try
        {
            using var conn = Database.GetConnection();

            using var cc = conn.CreateCommand();
            cc.CommandText = @"SELECT COUNT(*) FROM challans
                WHERE deductor_id=@d AND financial_year=@fy AND quarter=@q AND status='Paid'";
            cc.Parameters.AddWithValue("@d",  AppState.CurrentDeductorId);
            cc.Parameters.AddWithValue("@fy", AppState.CurrentFY);
            cc.Parameters.AddWithValue("@q",  _quarter);
            _statusChallanCount = (int)(long)(cc.ExecuteScalar() ?? 0L);

            using var ec = conn.CreateCommand();
            ec.CommandText = @"SELECT COUNT(*) FROM tds_entries
                WHERE deductor_id=@d AND financial_year=@fy AND quarter=@q AND status='Paid'";
            ec.Parameters.AddWithValue("@d",  AppState.CurrentDeductorId);
            ec.Parameters.AddWithValue("@fy", AppState.CurrentFY);
            ec.Parameters.AddWithValue("@q",  _quarter);
            _statusEntryCount = (int)(long)(ec.ExecuteScalar() ?? 0L);

            using var lc = conn.CreateCommand();
            lc.CommandText = @"SELECT COUNT(*) FROM tds_entries
                WHERE deductor_id=@d AND financial_year=@fy AND quarter=@q
                AND status='Paid' AND challan_no IS NOT NULL AND challan_no != ''";
            lc.Parameters.AddWithValue("@d",  AppState.CurrentDeductorId);
            lc.Parameters.AddWithValue("@fy", AppState.CurrentFY);
            lc.Parameters.AddWithValue("@q",  _quarter);
            _statusLinkedCount = (int)(long)(lc.ExecuteScalar() ?? 0L);

            // Determine active step
            if (_statusLinkedCount > 0 && _statusLinkedCount == _statusEntryCount)
                _activeStep = 3; // Ready to generate
            else if (_statusChallanCount > 0)
                _activeStep = 2;
            else
                _activeStep = 1;
        }
        catch { }
    }

    // ── Generate .txt only ──────────────────────────────────────────────────
    async Task GenerateTxtOnly()
    {
        if (!ValidateInputs()) return;
        _generating = true; _step = Step.GeneratingTxt;
        _result = ""; _logLines.Clear(); _fvuErrors.Clear();
        _lastTxtPath = ""; _lastFvuPath = ""; _lastZipPath = ""; _errorHtmlPath = "";
        StateHasChanged();

        try
        {
            var (ok, path, error) = await Task.Run(() =>
            {
                var data   = BuildReturnData();
                FolderManager.EnsureStructure(AppState.CurrentFY, _quarter); var outDir = FolderManager.SubFolder(AppState.CurrentFY, _quarter, "FVU");
                return Svc.GenerateFvu(data, outDir);
            });

            if (ok)
            {
                _lastTxtPath    = path;
                _result         = $"✅  Return file generated:\n{path}\n\nNext: Click 'Generate & Validate (FVU)' to validate, or open RPU manually.";
                _resultSeverity = Severity.Success;
                _activeStep     = 4;
            }
            else
            {
                _result         = "❌  " + error;
                _resultSeverity = Severity.Error;
            }
        }
        catch (Exception ex) { _result = "❌  " + ex.Message; _resultSeverity = Severity.Error; }

        _generating = false; _step = Step.Idle;
    }

    // ── Generate .txt then run NSDL FVU jar ────────────────────────────────
    async Task GenerateAndValidate()
    {
        if (!ValidateInputs()) return;
        _generating = true; _step = Step.GeneratingTxt;
        _result = ""; _logLines.Clear(); _fvuErrors.Clear();
        _lastTxtPath = ""; _lastFvuPath = ""; _lastZipPath = ""; _errorHtmlPath = "";
        StateHasChanged();

        string txtPath = "";
        string outDir  = "";

        // Step 1: Generate .txt
        try
        {
            var (ok, path, error) = await Task.Run(() =>
            {
                var data = BuildReturnData();
                outDir   = FolderManager.SubFolder(AppState.CurrentFY, _quarter, "FVU");
                return Svc.GenerateFvu(data, outDir);
            });

            if (!ok) { _result = "❌  " + error; _resultSeverity = Severity.Error; _generating = false; _step = Step.Idle; return; }
            txtPath      = path;
            _lastTxtPath = path;
            _logLines.Add($"[{Now()}] ✅ .txt generated: {Path.GetFileName(path)}");
            StateHasChanged();
        }
        catch (Exception ex) { _result = "❌  " + ex.Message; _resultSeverity = Severity.Error; _generating = false; _step = Step.Idle; return; }

        // Step 2: Run FVU jar
        _step = Step.RunningFvu;
        _logLines.Add($"[{Now()}] 🔄 Launching NSDL FVU utility...");
        StateHasChanged();

        try
        {
            var javaPath = Database.GetSetting("JavaPath", "");
            var fvuJar   = Database.GetSetting("FvuPath",  "");

            var progress = new Progress<string>(msg =>
            {
                _logLines.Add($"[{Now()}] {msg}");
                if (_logLines.Count > 50) _logLines.RemoveAt(0);
                InvokeAsync(StateHasChanged);
            });

            var fvuResult = await Svc.RunFvuUtilityAsync(txtPath, outDir, progress);

            if (fvuResult.Success && !string.IsNullOrEmpty(fvuResult.FvuFile))
            {
                _lastFvuPath    = fvuResult.FvuFile;
                _lastZipPath    = fvuResult.ZipFile;
                _errorHtmlPath  = fvuResult.ErrorHtmlFile;
                _fvuErrors      = fvuResult.Errors;
                var zipNote     = !string.IsNullOrEmpty(fvuResult.ZipFile)
                    ? $"\n📦 Zip: {Path.GetFileName(fvuResult.ZipFile)} — ready to upload to TIN-NSDL"
                    : "";
                _result         = $"✅  FVU Validated successfully!\n.fvu file: {Path.GetFileName(fvuResult.FvuFile)}\nJava: {fvuResult.JavaVersion}{zipNote}\n\nReady to upload to IT Portal.";
                _resultSeverity = Severity.Success;
                _activeStep     = 5;
                _logLines.Add($"[{Now()}] ✅ .fvu file created: {Path.GetFileName(fvuResult.FvuFile)}");
            }
            else
            {
                _errorHtmlPath  = fvuResult.ErrorHtmlFile;
                _fvuErrors      = fvuResult.Errors;
                _logLines.Add($"[{Now()}] ❌ FVU returned errors ({fvuResult.Errors.Count})");

                if (_fvuErrors.Count > 0)
                {
                    _result         = $"⚠️  FVU found {_fvuErrors.Count} error(s). Fix them and regenerate.\n.txt file is saved — open it in RPU to review.";
                    _resultSeverity = Severity.Warning;
                }
                else
                {
                    _result         = "❌  FVU utility error: " + fvuResult.ErrorMessage;
                    _resultSeverity = Severity.Error;
                }
            }
        }
        catch (Exception ex)
        {
            _result         = "❌  FVU run failed: " + ex.Message;
            _resultSeverity = Severity.Error;
            _logLines.Add($"[{Now()}] ❌ Exception: {ex.Message}");
        }

        _generating = false; _step = Step.Idle;
    }

    async Task GeneratePaperReturn()
    {
        if (!ValidateInputs()) return;
        _generating = true; _step = Step.PaperReturn; StateHasChanged();
        try
        {
            var path = await Task.Run(() =>
            {
                var data = BuildReturnData();
                FolderManager.EnsureStructure(AppState.CurrentFY, _quarter); var outDir = FolderManager.SubFolder(AppState.CurrentFY, _quarter, "FVU");
                Directory.CreateDirectory(outDir);
                var fileName = $"{_formType}_{data.Header.TanOfDeductor}_{AppState.CurrentFY.Replace("-","")}_{_quarter}_Paper.html";
                var outPath  = Path.Combine(outDir, fileName);
                return TDSPro.DAL.PaperReturnGenerator.Generate(data, outPath);
            });
            // Open in default browser for viewing / printing / save-as-PDF
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(path) { UseShellExecute = true });
            Snackbar.Add($"Paper return opened in browser. Use Ctrl+P → Save as PDF to download.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Paper return error: {ex.Message}", Severity.Error); }
        _generating = false; _step = Step.Idle;
    }

    async Task GenerateNil()
    {
        if (AppState.CurrentDeductorId == 0) { _nilResult = "Select a deductor first."; _nilSeverity = Severity.Warning; return; }
        if (string.IsNullOrWhiteSpace(_nilName)) { _nilResult = "Responsible person name is required."; _nilSeverity = Severity.Warning; return; }
        _generating = true; _nilResult = ""; StateHasChanged();
        try
        {
            var (ok, path, error) = await Task.Run(() =>
            {
                var data = Svc.BuildReturn(AppState.CurrentDeductorId, AppState.CurrentFY, _nilQuarter, _nilForm);
                data.Header.ResponsibleName = _nilName;
                data.Header.ResponsiblePan  = _nilPan;
                data.Challans.Clear();
                data.Deductees.Clear();
                FolderManager.EnsureStructure(AppState.CurrentFY, _nilQuarter + "_NIL"); var outDir = FolderManager.SubFolder(AppState.CurrentFY, _nilQuarter + "_NIL", "FVU");
                return Svc.GenerateFvu(data, outDir);
            });
            _nilResult   = ok ? $"NIL return generated:\n{path}" : "Error: " + error;
            _nilSeverity = ok ? Severity.Success : Severity.Error;
        }
        catch (Exception ex) { _nilResult = "Error: " + ex.Message; _nilSeverity = Severity.Error; }
        _generating = false;
    }

    // ── Helpers ────────────────────────────────────────────────────────────
    bool ValidateInputs()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return false; }
        if (_isCorrection && string.IsNullOrWhiteSpace(_prevPrn))
            { Snackbar.Add("Previous PRN is required for a correction return.", Severity.Warning); return false; }
        if (string.IsNullOrWhiteSpace(_responsibleName))
            { Snackbar.Add("Responsible person name is required.", Severity.Warning); return false; }
        return true;
    }

    TDSPro.DAL.Models.ReturnData BuildReturnData()
    {
        var data = Svc.BuildReturn(AppState.CurrentDeductorId, AppState.CurrentFY, _quarter, _formType);
        data.Header.IsCorrection    = _isCorrection;
        data.Header.PreviousPrn     = _prevPrn;
        data.Header.ResponsibleName = _responsibleName;
        data.Header.ResponsiblePan  = _responsiblePan;
        data.Header.Designation     = _designation;
        return data;
    }

    void OpenFolder(string filePath)
    {
        try
        {
            var dir = File.Exists(filePath) ? Path.GetDirectoryName(filePath) : filePath;
            if (dir != null) FolderManager.OpenFolder(dir);
        }
        catch { }
    }

    void OpenErrorReport()
    {
        try
        {
            if (!string.IsNullOrEmpty(_errorHtmlPath) && File.Exists(_errorHtmlPath))
                System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(_errorHtmlPath) { UseShellExecute = true });
        }
        catch { }
    }

    // ── Launch dialog ─────────────────────────────────────────────────────
    private bool   _launchOpen;
    private string _launchTitle    = "";
    private string _launchUser     = "";
    private string _launchPass     = "";
    private string _launchUrl      = "";
    void OpenPortalCard(PortalCard card)
    {
        if (!string.IsNullOrEmpty(card.CredKey))
        {
            _launchTitle    = card.Title + " Login";
            _launchUser     = card.CredUser;
            _launchPass     = AesEncryption.LoadCredential(card.CredKey, "");
            _launchUrl      = card.Url;
            _launchOpen     = true;
        }
        else
        {
            OpenUrl(card.Url);
        }
    }

    async Task LaunchConfirm()
    {
        _launchOpen = false;
        // Copy User ID to clipboard so user can paste it in the browser
        if (!string.IsNullOrEmpty(_launchUser))
        {
            System.Windows.Application.Current.Dispatcher.Invoke(
                () => System.Windows.Clipboard.SetText(_launchUser));
            Snackbar.Add("User ID copied — paste it in the browser login field.", Severity.Info);
        }
        await OpenUrl(_launchUrl);
    }

    async Task CopyText(string text)
    {
        try
        {
            // Use WPF clipboard — persists when focus moves to external browser window
            System.Windows.Application.Current.Dispatcher.Invoke(
                () => System.Windows.Clipboard.SetText(text));
            Snackbar.Add("Copied!", Severity.Success);
        }
        catch
        {
            // Fallback to JS if WPF clipboard fails
            try { await JS.InvokeAsync<bool>("window.tdspro.copyToClipboard", text); }
            catch { }
            Snackbar.Add("Copied!", Severity.Success);
        }
    }

    Task OpenUrl(string url)
    {
        try { System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(url) { UseShellExecute = true }); } catch { }
        return Task.CompletedTask;
    }

    static string CardStyle(string color)     => $"border-radius:8px;cursor:pointer;border-left:4px solid {color}";
    static string CardTextStyle(string color) => $"font-size:12px;font-weight:600;color:{color}";
    static string Now() => DateTime.Now.ToString("HH:mm:ss");

    static string CurrentAutoQuarter()
    {
        int m = DateTime.Today.Month;
        return m >= 4 && m <= 6 ? "Q1" : m >= 7 && m <= 9 ? "Q2" : m >= 10 && m <= 12 ? "Q3" : "Q4";
    }
}

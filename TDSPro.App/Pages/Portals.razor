@page "/portals"
@inject AppStateService AppState
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using System.IO
@using Microsoft.AspNetCore.Components.Web

<MudText Typo="Typo.h5" Class="mb-4">Portal Credentials</MudText>
<MudText Color="Color.Secondary" Class="mb-4">
    Credentials are stored encrypted in the database. Use these to quickly access government portals.
</MudText>

<MudGrid>
    @* ── TRACES ── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">TRACES</MudText>
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">TDS Reconciliation Analysis and Correction Enabling System</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInBrowser" Color="Color.Primary"
                                   OnClick="OpenTraces" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pb-1">
                <MudTextField @bind-Value="_tracesUser" Label="User ID" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                <MudTextField @bind-Value="_tracesPass" Label="Password" Margin="Margin.Dense" Class="mb-2"
                              InputType="@(_showTraces ? InputType.Text : InputType.Password)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showTraces ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="ToggleTracesPass" />
                <MudTextField Value="@_tracesTan" Label="TAN" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="ABCD12345E" MaxLength="10" Class="tan-field"
                              Style="text-transform:uppercase;font-family:monospace;letter-spacing:1px"
                              Immediate="true" ValueChanged="@((string v) => _tracesTan = v.ToUpper().Trim())" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SaveTraces">Save</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearTraces">Clear</MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.FolderOpen"
                           OnClick="OpenTracesDownloads">Downloads Folder</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* ── IT PORTAL ── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Success" />
                        <MudText Typo="Typo.h6">IT Portal</MudText>
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Income Tax e-Filing Portal (www.incometax.gov.in)</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInBrowser" Color="Color.Success"
                                   OnClick="OpenItPortal" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pb-1">
                <MudTextField Value="@_itUser" Label="PAN / User ID" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2 pan-field"
                              MaxLength="10" Style="text-transform:uppercase;font-family:monospace;letter-spacing:1px"
                              Immediate="true" ValueChanged="@((string v) => _itUser = v.ToUpper().Trim())" />
                <MudTextField @bind-Value="_itPass" Label="Password" Margin="Margin.Dense" Class="mb-2"
                              InputType="@(_showIt ? InputType.Text : InputType.Password)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showIt ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="ToggleItPass" />
                <MudTextField Value="@_itPan" Label="PAN" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="ABCDE1234F" MaxLength="10" Class="pan-field"
                              Style="text-transform:uppercase;font-family:monospace;letter-spacing:1px"
                              Immediate="true" ValueChanged="@((string v) => _itPan = v.ToUpper().Trim())" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="SaveItPortal">Save</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearItPortal">Clear</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* ── TIN-NSDL ── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Warning" />
                        <MudText Typo="Typo.h6">TIN-NSDL</MudText>
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Challan payment, FVU download, e-TDS returns</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInBrowser" Color="Color.Warning"
                                   OnClick="OpenTinNsdl" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pb-1">
                <MudTextField Value="@_tinUser" Label="TAN" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2 tan-field"
                              Placeholder="ABCD12345E" MaxLength="10"
                              Style="text-transform:uppercase;font-family:monospace;letter-spacing:1px"
                              Immediate="true" ValueChanged="@((string v) => _tinUser = v.ToUpper().Trim())" />
                <MudTextField @bind-Value="_tinPass" Label="Password" Margin="Margin.Dense"
                              InputType="@(_showTin ? InputType.Text : InputType.Password)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showTin ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="ToggleTinPass" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="SaveTin">Save</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearTin">Clear</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* ── QUICK LINKS ── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Quick Links</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Link" OnClick="OpenTraces">
                        TRACES — tdscpc.gov.in
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Link" OnClick="OpenItPortal">
                        IT e-Filing — incometax.gov.in
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Link" OnClick="OpenTinNsdl">
                        TIN-NSDL — www.protean-tinpan.com
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Link" OnClick="OpenOltas">
                        OLTAS / CSI — eportal.incometax.gov.in
                    </MudListItem>
                </MudList>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FolderOpen"
                           OnClick="OpenDataFolder">Open Data Folder</MudButton>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FolderOpen"
                           OnClick="OpenReturnsFolder">Open Returns Folder</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@* ── Launch Dialog — shows credentials before opening browser ── *@
<MudDialog @bind-Visible="_launchOpen" Options='new DialogOptions { MaxWidth=MaxWidth.ExtraSmall, FullWidth=true }'>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.OpenInBrowser" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@_launchTitle</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Copy your credentials before the browser opens.
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="9">
                <MudTextField Value="@_launchUser" Label="User ID / TAN / PAN"
                              Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly="true"
                              Style="font-family:monospace;font-weight:600" />
            </MudItem>
            <MudItem xs="3" Class="d-flex align-center">
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                               OnClick="@(() => CopyText(_launchUser))" />
            </MudItem>
            @if (!string.IsNullOrEmpty(_launchPass))
            {
                <MudItem xs="9">
                    <MudTextField Value="@_launchPass" Label="Password"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly="true"
                                  InputType="@(_launchShowPass ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_launchShowPass ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _launchShowPass = !_launchShowPass)" />
                </MudItem>
                <MudItem xs="3" Class="d-flex align-center">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                   OnClick="@(() => CopyText(_launchPass))" />
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Password not saved yet. Close this, type your password in the <b>Password</b> field on this page, click <b>Save</b> — then the copy button will work next time.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _launchOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.OpenInBrowser"
                   OnClick="LaunchConfirm">Open Browser</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private string _tracesUser = "";
    private string _tracesPass = "";
    private string _tracesTan  = "";
    private bool   _showTraces;

    private string _itUser = "";
    private string _itPass = "";
    private string _itPan  = "";
    private bool   _showIt;

    private string _tinUser = "";
    private string _tinPass = "";
    private bool   _showTin;

    // ── Launch dialog state ───────────────────────────────────────────────
    private bool   _launchOpen;
    private string _launchTitle   = "";
    private string _launchUser    = "";
    private string _launchPass    = "";
    private string _launchUrl     = "";
    private bool   _launchShowPass;

    protected override void OnInitialized()
    {
        _tracesUser = Database.GetSetting("TracesUserId", "");
        _tracesTan  = Database.GetSetting("TracesTan",    AppState.CurrentDeductorTan);
        _itUser     = Database.GetSetting("ItPortalUserId", "");
        _itPan      = Database.GetSetting("ItPortalPan",    "");
        _tinUser    = Database.GetSetting("TinNsdlTan",  AppState.CurrentDeductorTan);
    }

    void ToggleTracesPass() => _showTraces = !_showTraces;
    void ToggleItPass()     => _showIt     = !_showIt;
    void ToggleTinPass()    => _showTin    = !_showTin;

    void SaveTraces()
    {
        Database.SetSetting("TracesUserId", _tracesUser);
        Database.SetSetting("TracesTan",    _tracesTan);
        if (!string.IsNullOrEmpty(_tracesPass))
        {
            AesEncryption.SaveCredential("TracesPassword", _tracesPass);
            _tracesPass = "";
        }
        Snackbar.Add("TRACES credentials saved.", Severity.Success);
    }

    void ClearTraces()
    {
        _tracesUser = _tracesPass = _tracesTan = "";
        Database.SetSetting("TracesUserId", "");
        Database.SetSetting("TracesTan", "");
        AesEncryption.ClearCredential("TracesPassword");
        Snackbar.Add("TRACES credentials cleared.", Severity.Info);
    }

    void SaveItPortal()
    {
        Database.SetSetting("ItPortalUserId", _itUser);
        Database.SetSetting("ItPortalPan",    _itPan);
        if (!string.IsNullOrEmpty(_itPass))
        {
            AesEncryption.SaveCredential("ItPortalPassword", _itPass);
            _itPass = "";
        }
        Snackbar.Add("IT Portal credentials saved.", Severity.Success);
    }

    void ClearItPortal()
    {
        _itUser = _itPass = _itPan = "";
        Database.SetSetting("ItPortalUserId", "");
        Database.SetSetting("ItPortalPan", "");
        AesEncryption.ClearCredential("ItPortalPassword");
        Snackbar.Add("IT Portal credentials cleared.", Severity.Info);
    }

    void SaveTin()
    {
        Database.SetSetting("TinNsdlTan", _tinUser);
        if (!string.IsNullOrEmpty(_tinPass))
        {
            AesEncryption.SaveCredential("TinNsdlPassword", _tinPass);
            _tinPass = "";
        }
        Snackbar.Add("TIN-NSDL credentials saved.", Severity.Success);
    }

    void ClearTin()
    {
        _tinUser = _tinPass = "";
        Database.SetSetting("TinNsdlTan", "");
        AesEncryption.ClearCredential("TinNsdlPassword");
        Snackbar.Add("TIN-NSDL credentials cleared.", Severity.Info);
    }

    // ── Launch helpers ────────────────────────────────────────────────────
    void ShowLaunchDialog(string title, string userId, string credKey, string url)
    {
        _launchTitle    = title;
        _launchUser     = userId;
        _launchPass     = AesEncryption.LoadCredential(credKey, "");
        _launchUrl      = url;
        _launchShowPass = false;
        _launchOpen     = true;
    }

    async Task LaunchConfirm()
    {
        _launchOpen = false;
        await OpenUrl(_launchUrl);
    }

    async Task CopyText(string text)
    {
        try
        {
            System.Windows.Application.Current.Dispatcher.Invoke(
                () => System.Windows.Clipboard.SetText(text));
            Snackbar.Add("Copied to clipboard!", Severity.Success);
        }
        catch
        {
            try { await JS.InvokeAsync<bool>("window.tdspro.copyToClipboard", text); }
            catch { }
            Snackbar.Add("Copied to clipboard!", Severity.Success);
        }
    }

    async Task OpenUrl(string url)
    {
        try { System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(url) { UseShellExecute = true }); } catch { }
        await Task.CompletedTask;
    }

    async Task OpenTraces()   { ShowLaunchDialog("TRACES Login", _tracesTan, "TracesPassword", "https://traces.tdscpc.gov.in/auth/login/loginScreen"); await Task.CompletedTask; }
    async Task OpenItPortal() { ShowLaunchDialog("IT Portal Login", _itUser, "ItPortalPassword", "https://eportal.incometax.gov.in/iec/foservices/#/login"); await Task.CompletedTask; }
    async Task OpenTinNsdl()  { ShowLaunchDialog("TIN-NSDL Login", _tinUser, "TinNsdlPassword", "https://onlineservices.tin.egov-nsdl.com/etaxnew/tdsnontds.jsp"); await Task.CompletedTask; }
    async Task OpenOltas()    => await OpenUrl("https://eportal.incometax.gov.in/iec/foservices/#/login");

    void OpenTracesDownloads()
    {
        try { FolderManager.OpenFolder(FolderManager.SubFolder(AppState.CurrentFY, FolderManager.DetectQuarter(DateTime.Today), "Conso")); } catch { }
    }

    void OpenDataFolder()
    {
        try { FolderManager.OpenFolder(FolderManager.BasePath); } catch { }
    }

    void OpenReturnsFolder()
    {
        try { FolderManager.OpenCurrentQuarterFolder(); } catch { }
    }
}

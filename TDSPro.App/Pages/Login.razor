@page "/login"
@page "/"
@layout EmptyLayout
@inject AppStateService AppState
@inject NavigationManager Nav
@inject IDialogService DialogSvc
@using TDSPro.DAL

<MudPaper Class="pa-8 mx-auto mt-16" Style="max-width:420px;" Elevation="4">
    <div class="d-flex align-center justify-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Size="Size.Large" Class="mr-2" />
        <MudText Typo="Typo.h5" Style="font-weight:700; color:#1565C0">TDS Pro</MudText>
    </div>

    <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-6" Color="Color.Secondary">
        TDS Compliance Software — Income-tax Act 2025
    </MudText>

    <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                  Class="mb-4" @onkeyup="OnKeyUp" />

    <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                  Adornment="Adornment.End"
                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                  OnAdornmentClick="() => _showPassword = !_showPassword"
                  Class="mb-2" @onkeyup="OnKeyUp" />

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_errorMsg</MudAlert>
    }

    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
               OnClick="DoLogin" Disabled="_loading" Class="mt-2" Size="Size.Large">
        @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
        Sign In
    </MudButton>

    <div class="d-flex justify-center mt-3">
        <MudButton Variant="Variant.Text" Size="Size.Small"
                   Style="font-size:11px;font-weight:600;letter-spacing:.8px;color:#1565C0;text-transform:uppercase"
                   OnClick="() => _showForgot = !_showForgot">
            @(_showForgot ? "✕  Cancel" : "Forgot Password?")
        </MudButton>
    </div>

    @if (_showForgot)
    {
        <div style="background:#f8f9ff;border:1px solid #c5cae9;border-radius:8px;padding:16px;margin-top:12px">
            <div style="font-size:12px;font-weight:700;color:#1565C0;letter-spacing:.4px;text-transform:uppercase;margin-bottom:12px">
                Reset Password
            </div>
            <MudTextField @bind-Value="_resetUser" Label="Username" Variant="Variant.Outlined" Class="mb-2" />
            <MudTextField @bind-Value="_resetNew" Label="New Password" Variant="Variant.Outlined"
                          InputType="InputType.Password" Class="mb-2" />
            <MudTextField @bind-Value="_resetConfirm" Label="Confirm Password" Variant="Variant.Outlined"
                          InputType="InputType.Password" Class="mb-3" />
            @if (!string.IsNullOrEmpty(_resetMsg))
            {
                <MudAlert Severity="@_resetSeverity" Dense="true" Class="mb-2">@_resetMsg</MudAlert>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" OnClick="DoReset">
                Reset Password
            </MudButton>
            <div style="font-size:10px;color:#999;text-align:center;margin-top:8px">
                Admin reset requires physical access. Contact your system admin if locked out.
            </div>
        </div>
    }

    <MudDivider Class="mt-5 mb-3" />
    <div style="text-align:center;font-size:11px;color:#aaa;letter-spacing:.3px">
        v@(AppConstants.AppVersion) &nbsp;·&nbsp; @DateTime.Today.Year &nbsp;·&nbsp; Developed by
        <span style="font-weight:700;color:#1565C0">Arjun Panda</span>
    </div>
</MudPaper>

@code {
    private string _username = "";
    private string _password = "";
    private string _errorMsg = "";
    private bool   _showPassword;
    private bool   _loading;
    private int    _failCount;

    // Forgot password
    private bool   _showForgot;
    private string _resetUser    = "";
    private string _resetNew     = "";
    private string _resetConfirm = "";
    private string _resetMsg     = "";
    private Severity _resetSeverity = Severity.Error;

    protected override void OnInitialized()
    {
        if (AppState.IsLoggedIn)
            Nav.NavigateTo("/dashboard");

        if (AppState.AutoLogin)
        {
            _username = "admin";
            _password = "admin@123";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !AppState.IsLoggedIn && AppState.AutoLogin)
            await DoLogin();
    }

    async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
            { _errorMsg = "Username and password are required."; return; }
        if (_failCount >= 5) { _errorMsg = "Account locked — too many failed attempts."; return; }
        _loading = true; _errorMsg = "";
        await Task.Yield();

        try
        {
            using var conn = Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = "SELECT role FROM users WHERE username=@u AND password=@p AND status='Active'";
            cmd.Parameters.AddWithValue("@u", _username.Trim());
            cmd.Parameters.AddWithValue("@p", HashPassword(_password));
            var role = cmd.ExecuteScalar() as string;

            if (role != null)
            {
                AppState.Login(_username.Trim(), role);
                Database.LogAction(_username.Trim(), "LOGIN", "Auth", "Login successful");

                // Show company + FY selector before entering the app
                var options = new DialogOptions
                {
                    MaxWidth = MaxWidth.Small,
                    FullWidth = true,
                    CloseOnEscapeKey = false,
                    BackdropClick = false
                };
                var dialog = await DialogSvc.ShowAsync<CompanySelector>("", options);
                var result = await dialog.Result;

                // Whether they picked a company or went to add new, navigate into app
                Nav.NavigateTo("/dashboard");
            }
            else
            {
                _failCount++;
                _errorMsg = $"Invalid credentials. {5 - _failCount} attempt(s) remaining.";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = "Login error: " + ex.Message;
        }
        _loading = false;
    }

    void OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = DoLogin();
    }

    static string HashPassword(string pw) =>
        Database.HashPassword(pw);

    void DoReset()
    {
        _resetMsg = "";
        if (string.IsNullOrWhiteSpace(_resetUser)) { _resetMsg = "Enter username."; return; }
        if (_resetNew.Length < 6) { _resetMsg = "Password must be at least 6 characters."; return; }
        if (_resetNew != _resetConfirm) { _resetMsg = "Passwords do not match."; return; }

        try
        {
            using var conn = Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = "UPDATE users SET password=@p WHERE username=@u";
            cmd.Parameters.AddWithValue("@u", _resetUser.Trim());
            cmd.Parameters.AddWithValue("@p", HashPassword(_resetNew));
            int rows = cmd.ExecuteNonQuery();
            if (rows == 0) { _resetMsg = "Username not found."; return; }
            _resetSeverity = Severity.Success;
            _resetMsg = "Password reset successfully. You can now log in.";
            _resetUser = _resetNew = _resetConfirm = "";
            Database.LogAction("system", "PASSWORD_RESET", "Auth", $"Password reset for {_resetUser}");
        }
        catch (Exception ex) { _resetMsg = "Error: " + ex.Message; }
    }
}

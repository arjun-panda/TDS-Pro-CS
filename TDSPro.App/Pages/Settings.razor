    // ── Fully automated: download zip from Protean → extract → install ────────
    async Task InstallFvuFromDownloads()
    {
        _fvuInstalling    = true;
        _fvuInstallMsg    = "Connecting to Protean server...";
        _fvuInstallSeverity = Severity.Info;
        StateHasChanged();

        var (ok, msg) = await Task.Run(async () =>
        {
            const string fvuInstallDir = @"C:\Program Files\TDS Pro\FVU";
            const string directUrl     = "https://tinpan.proteantech.in/downloads/e-tds/download/TDS_STANDALONE_FVU_9.4.zip";

            // ── Step 1: Remove any corrupt jar (< 50 KB is suspicious) ────────
            var existingJar = Path.Combine(fvuInstallDir, "TDS_STANDALONE_FVU_9.4.jar");
            if (File.Exists(existingJar) && new FileInfo(existingJar).Length < 51_200)
                File.Delete(existingJar);

            // ── Step 2: Try direct download ───────────────────────────────────
            var zipPath = Path.Combine(Path.GetTempPath(), "TDS_STANDALONE_FVU_9.4.zip");
            try
            {
                using var http = new System.Net.Http.HttpClient();
                http.Timeout = TimeSpan.FromSeconds(120);
                http.DefaultRequestHeaders.Add("User-Agent", "TDSPro/2.0");

                // Report progress via return tuple — update msg inline
                using var response = await http.GetAsync(directUrl, System.Net.Http.HttpCompletionOption.ResponseHeadersRead);
                if (!response.IsSuccessStatusCode)
                    return (false, $"Download failed: HTTP {(int)response.StatusCode}. Check internet connection.");

                var total = response.Content.Headers.ContentLength ?? 0;
                using var fs = new FileStream(zipPath, FileMode.Create, FileAccess.Write, FileShare.None);
                using var stream = await response.Content.ReadAsStreamAsync();
                var buf = new byte[81920];
                long downloaded = 0;
                int read;
                while ((read = await stream.ReadAsync(buf)) > 0)
                {
                    await fs.WriteAsync(buf.AsMemory(0, read));
                    downloaded += read;
                }
            }
            catch (Exception ex)
            {
                // ── Step 2b: Fallback — scan local drives for a previously downloaded zip ──
                var profile = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
                var scanDirs = new[]
                {
                    Path.Combine(profile, "Downloads"),
                    Path.Combine(profile, "OneDrive", "Downloads"),
                    Path.Combine(profile, "OneDrive - Personal", "Downloads"),
                    Environment.GetFolderPath(Environment.SpecialFolder.Desktop),
                    Path.Combine(profile, "OneDrive", "Desktop"),
                    Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
                    @"C:\FVU", @"C:\NSDL",
                };
                var localZip = scanDirs
                    .Where(Directory.Exists)
                    .SelectMany(d => Directory.GetFiles(d, "*.zip", SearchOption.TopDirectoryOnly))
                    .Where(f => { var n = Path.GetFileNameWithoutExtension(f).ToUpperInvariant(); return n.Contains("FVU") || n.Contains("STANDALONE") || n.Contains("ETDS"); })
                    .OrderByDescending(File.GetLastWriteTime)
                    .FirstOrDefault();

                if (localZip == null)
                    return (false, $"Auto-download failed ({ex.Message}) and no local FVU zip found.\nPlease download manually from https://www.protean-tinpan.com and click Install again.");

                zipPath = localZip;
            }

            // ── Step 3: Extract zip ────────────────────────────────────────────
            var tempExtract = Path.Combine(Path.GetTempPath(), "TDSProFVU_" + Guid.NewGuid().ToString("N")[..6]);
            try
            {
                System.IO.Compression.ZipFile.ExtractToDirectory(zipPath, tempExtract, overwriteFiles: true);
            }
            catch (Exception ex)
            {
                return (false, $"Zip extraction failed: {ex.Message}");
            }

            // ── Step 4: Locate main jar ────────────────────────────────────────
            var mainJar = Directory.GetFiles(tempExtract, "*.jar", SearchOption.AllDirectories)
                .FirstOrDefault(f => { var n = Path.GetFileName(f).ToUpperInvariant(); return n.StartsWith("TDS_STANDALONE_FVU") || n.StartsWith("TDS_FVU"); });

            if (mainJar == null)
            {
                try { Directory.Delete(tempExtract, true); } catch { }
                return (false, "Zip extracted but no TDS_STANDALONE_FVU*.jar found inside.");
            }

            // ── Step 5: Validate jar is a real zip (jars are zip files) ───────
            try { System.IO.Compression.ZipFile.OpenRead(mainJar).Dispose(); }
            catch { try { Directory.Delete(tempExtract, true); } catch { } return (false, "Downloaded jar appears corrupt. Please retry."); }

            // ── Step 6: Install all files ──────────────────────────────────────
            try
            {
                Directory.CreateDirectory(fvuInstallDir);
                foreach (var file in Directory.GetFiles(Path.GetDirectoryName(mainJar)!, "*.*"))
                    File.Copy(file, Path.Combine(fvuInstallDir, Path.GetFileName(file)), overwrite: true);
            }
            catch (Exception ex)
            {
                return (false, $"Install to {fvuInstallDir} failed: {ex.Message}");
            }
            finally { try { Directory.Delete(tempExtract, true); } catch { } }

            return (true, $"✅ FVU {Path.GetFileName(mainJar)} installed to {fvuInstallDir}");
        });

        if (ok)
        {
            _fvuInstallSeverity = Severity.Success;
            AutoDetectFvu();
        }
        else
        {
            _fvuInstallSeverity = Severity.Warning;
        }
        _fvuInstallMsg = msg;
        _fvuInstalling = false;
    }

    static string GetJavaVersion(string javaExe)
    {
        try
        {
            var p = System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(javaExe, "-version")
                { RedirectStandardError = true, UseShellExecute = false, CreateNoWindow = true });
            p?.WaitForExit(3000);
            var line = p?.StandardError.ReadLine() ?? "";
            // e.g. 'openjdk version "17.0.13"'
            var m = System.Text.RegularExpressions.Regex.Match(line, "\"([^\"]+)\"");
            return m.Success ? $"Java {m.Groups[1].Value}" : line.Split('\n')[0].Trim();
        }
        catch { return ""; }
    }


@page "/audit"
@using System.IO
@inject ISnackbar Snackbar
@inject AppStateService AppState

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">Audit Log</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Success"
               StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv">
        Export CSV
    </MudButton>
</div>

<MudGrid Class="mb-3" Spacing="2">
    <MudItem xs="4">
        <MudTextField @bind-Value="_search" Placeholder="Search user, action, module, details..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="2">
        <DateField Value="_fromDate" ValueChanged="d => _fromDate = d" Label="From Date"
                   Variant="Variant.Outlined" Class="date-field" />
    </MudItem>
    <MudItem xs="2">
        <DateField Value="_toDate" ValueChanged="d => _toDate = d" Label="To Date"
                   Variant="Variant.Outlined" Class="date-field" />
    </MudItem>
    <MudItem xs="2">
        <MudSelect @bind-Value="_moduleFilter" Label="Module" Variant="Variant.Outlined"
                   AnchorOrigin="Origin.BottomCenter">
            <MudSelectItem Value='""'>All Modules</MudSelectItem>
            @foreach (var m in _modules)
            { <MudSelectItem Value="@m">@m</MudSelectItem> }
        </MudSelect>
    </MudItem>
    <MudItem xs="2" Class="d-flex align-end">
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearFilters">Clear</MudButton>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
    Showing @FilteredItems.Count() of @_items.Count entries
</MudText>

<div style="height:calc(100vh - 270px);overflow:hidden">
<MudDataGrid T="LogEntry" Items="FilteredItems" Hover="true" Striped="true" Dense="true"
             SortMode="SortMode.Single" FixedHeader="true" Height="calc(100vh - 270px)">
    <Columns>
        <PropertyColumn Property="x => x.CreatedAt" Title="Timestamp" Format="dd-MMM-yyyy HH:mm:ss" />
        <PropertyColumn Property="x => x.Username"  Title="User" />
        <PropertyColumn Property="x => x.Action"    Title="Action" />
        <PropertyColumn Property="x => x.Module"    Title="Module" />
        <PropertyColumn Property="x => x.Details"   Title="Details" />
    </Columns>
</MudDataGrid>
</div>

@code {
    public class LogEntry
    {
        public string   Username  { get; set; } = "";
        public string   Action    { get; set; } = "";
        public string   Module    { get; set; } = "";
        public string   Details   { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }

    private List<LogEntry> _items  = new();
    private List<string>     _modules = new();
    private string   _search       = "";
    private string   _moduleFilter = "";
    private DateTime? _fromDate;
    private DateTime? _toDate;

    private IEnumerable<LogEntry> FilteredItems => _items.Where(e =>
        (string.IsNullOrEmpty(_search) ||
         e.Username.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         e.Action.Contains(_search,   StringComparison.OrdinalIgnoreCase) ||
         e.Module.Contains(_search,   StringComparison.OrdinalIgnoreCase) ||
         e.Details.Contains(_search,  StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_moduleFilter) || e.Module == _moduleFilter) &&
        (_fromDate == null || e.CreatedAt.Date >= _fromDate.Value.Date) &&
        (_toDate   == null || e.CreatedAt.Date <= _toDate.Value.Date));

    protected override void OnInitialized()
    {
        try
        {
            using var conn = TDSPro.DAL.Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = "SELECT username, action, module, details, created_at FROM audit_log ORDER BY created_at DESC LIMIT 2000";
            using var rd = cmd.ExecuteReader();
            while (rd.Read())
            {
                var tsRaw = rd.IsDBNull(4) ? "" : rd.GetString(4);
                _items.Add(new LogEntry
                {
                    Username  = rd.IsDBNull(0) ? "" : rd.GetString(0),
                    Action    = rd.IsDBNull(1) ? "" : rd.GetString(1),
                    Module    = rd.IsDBNull(2) ? "" : rd.GetString(2),
                    Details   = rd.IsDBNull(3) ? "" : rd.GetString(3),
                    CreatedAt = DateTime.TryParse(tsRaw, out var dt) ? dt : DateTime.MinValue
                });
            }
            _modules = _items.Select(e => e.Module).Distinct().OrderBy(m => m).ToList();
        }
        catch (Exception ex) { Snackbar.Add("Failed to load audit log: " + ex.Message, Severity.Error); }
    }

    void ClearFilters()
    {
        _search = ""; _moduleFilter = ""; _fromDate = null; _toDate = null;
    }

    void ExportCsv()
    {
        try
        {
            var folder = Path.Combine(FolderManager.CompanyFolder, "Reports");
            Directory.CreateDirectory(folder);
            var path = Path.Combine(folder, $"AuditLog_{DateTime.Now:yyyyMMdd_HHmmss}.csv");
            var rows = new System.Text.StringBuilder();
            rows.AppendLine("Timestamp,User,Action,Module,Details");
            foreach (var e in FilteredItems)
            {
                var det = e.Details.Replace('"', '\'');
                rows.AppendLine($"\"{e.CreatedAt:dd-MMM-yyyy HH:mm:ss}\",\"{e.Username}\",\"{e.Action}\",\"{e.Module}\",\"{det}\"");
            }
            File.WriteAllText(path, rows.ToString(), System.Text.Encoding.UTF8);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Exported: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Export failed: " + ex.Message, Severity.Error); }
    }

}

    void SaveEmployee()
    {
        if (_editingEmployee == null) return;
        if (string.IsNullOrWhiteSpace(_editingEmployee.EmployeeCode)) { _empError = "Employee Code is required."; return; }
        if (string.IsNullOrWhiteSpace(_editingEmployee.Name))         { _empError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_editingEmployee.Pan))          { _empError = "PAN is required."; return; }
        if (_empJoin == null)                                          { _empError = "Date of Joining is required."; return; }

        // Flush named allowances total into the salary structure before saving
        if (_editingEmployee.Salary != null)
            _editingEmployee.Salary.OtherAllowance = _otherAllowances.Sum(a => a.Amount);

        var (ok, msg) = PayrollSvc.SaveEmployee(_editingEmployee);
        if (!ok) { _empError = msg; return; }

        _salaryStructureNeedsReview = false;
        LoadEmployees();
        _showEmployeeForm = false;
        _editingEmployee  = null;
        Snackbar.Add("Employee saved.", Severity.Success);
    }

    async Task DeleteEmployee(Employee emp)
    {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Employee?",

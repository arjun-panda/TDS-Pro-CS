    // ── Static helpers ────────────────────────────────────────────────────────

    static MonthlySalaryEntry BuildEntryFromRun(PayrollRun run) => new()
    {
        EmployeeName     = run.EmployeeName,
        Pan              = run.Pan,
        Month            = run.Month, Year = run.Year,
        FinancialYear    = run.FinancialYear,
        Basic            = run.Basic, HRA = run.Hra, DaAmount = run.Da,
        SpecialAllowance = run.Special,
        MedicalAllowance = run.Medical,
        Lta              = run.Lta,
        OtherAllowances  = run.Other,
        PfEmployee       = run.PfEmployee,
        ProfessionalTax  = run.ProfessionalTax,
        TdsDeducted      = run.TdsDeducted,
        GrossPayment     = run.GrossSalary,
        NetSalary        = run.NetPay,
    };

    static AnnualComputation BuildAnnualFromRun(PayrollRun run)
    {
        var annual = new AnnualComputation
        {
            ChosenRegime   = run.TaxRegimeUsed ?? "New",
            YtdTdsDeducted = run.YtdTds,
            MonthsRemaining = 0,
        };
        var cr = new RegimeResult
        {
            RegimeName        = run.TaxRegimeUsed ?? "New",
            GrossSalary       = run.GrossSalary * 12,
            StandardDeduction = run.StandardDeduction,
            HraExemption      = run.HraExemption * 12,
            Chapter6A         = run.Chapter6ADeduction,
            TotalIncome       = run.TaxableIncome,
            TaxOnIncome       = run.AnnualTax,
            TaxAfterRebate    = run.AnnualTax,
            Surcharge         = run.Surcharge,
            Cess              = run.Cess,
            TotalTax          = run.TotalAnnualTax,
        };
        if (annual.ChosenRegime == "New") annual.NewRegime = cr;
        else                              annual.OldRegime = cr;
        return annual;
    }

    void DownloadSlip(PayrollRun run, bool html)
    {
        try
        {
            var entry = SalarySvc.Get(run.EmployeeId, run.FinancialYear, run.Month)
                        ?? BuildEntryFromRun(run);
            var emp = PayrollSvc.GetEmployees(AppState.CurrentDeductorId)
                          .FirstOrDefault(e => e.Id == run.EmployeeId)
                      ?? new Employee { Id = run.EmployeeId, EmployeeCode = run.EmployeeCode, Name = run.EmployeeName, Pan = run.Pan, TaxRegime = run.TaxRegimeUsed };
            var deductors = DeductorSvc.GetAll();
            var ded = deductors.FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();

            // Recompute annual using employee's current regime — saved run may have stale regime
            AnnualComputation annual;
            try
            {
                var decl = PayrollSvc.GetDeclaration(emp.Id, run.FinancialYear)
                           ?? new TDSPro.DAL.Models.TaxDeclaration { EmployeeId = emp.Id, FinancialYear = run.FinancialYear };
                annual = SalarySvc.ComputeMonth(entry, emp, run.FinancialYear, decl);
            }
            catch
            {
                annual = BuildAnnualFromRun(run);
            }

            var folder = FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);

            var path = html
                ? SalarySlipExport.GenerateHtml(entry, annual, emp, ded, folder)
                : SalarySlipExport.GenerateExcel(entry, annual, emp, ded, folder);

            FolderManager.OpenFolder(Path.GetDirectoryName(path)!);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ex.Message, Severity.Error); }
    }

    void DownloadAnnual(EmployeeYearSummary summary, bool html)
    {
        try
        {
            var emp = PayrollSvc.GetEmployees(AppState.CurrentDeductorId)
                          .FirstOrDefault(e => e.Id == summary.EmployeeId)
                      ?? new Employee { Id = summary.EmployeeId, EmployeeCode = summary.EmployeeCode, Name = summary.EmployeeName };
            var deductors = DeductorSvc.GetAll();
            var ded = deductors.FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();

            // Build AnnualComputation from year summary runs
            var runs = PayrollSvc.GetRunsForFY(AppState.CurrentFY, AppState.CurrentDeductorId)
                           .Where(r => r.EmployeeId == summary.EmployeeId)
                           .ToList();
            if (!runs.Any()) { Snackbar.Add("No runs found for this employee.", Severity.Warning); return; }

            var lastRun = runs.OrderByDescending(r => r.Month == 3 ? 15 : r.Month).First();
            var annual  = BuildAnnualFromRun(lastRun);

            var folder = FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);

            var path = html
                ? SalarySlipExport.GenerateAnnualHtml(annual, emp, AppState.CurrentFY, folder, ded)
                : SalarySlipExport.GenerateAnnualExcel(annual, emp, AppState.CurrentFY, folder, ded);

            FolderManager.OpenFolder(Path.GetDirectoryName(path)!);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ex.Message, Severity.Error); }
    }

    // ── Salary Data Tab ──────────────────────────────────────────────────────

    void OnTabChanged(int index)
    {
        // Tab 1 = Salary Data — reload from DB so Monthly Run results are always visible
        if (index == 1 && _sdEmpId > 0 && _sdMonth > 0)
        {
            SelectSdMonth(_sdMonth);
            RefreshSdMonthStrip();
        }
    }

    void OnSdEmployeeChanged(int empId)
    {
        _sdEmpId = empId;
        _sdAnnual = null;
        if (empId == 0) { _sdMonth = 0; return; }
        // Reload employees so salary structure is always fresh from DB
        LoadEmployees();
        RefreshSdMonthStrip();
        SelectSdMonth(DateTime.Today.Month);
    }

    void RefreshSdMonthStrip()
    {
        if (_sdEmpId == 0) return;
        var saved = SalarySvc.GetAllForFY(_sdEmpId, AppState.CurrentFY);
        for (int i = 0; i < _fyMonths.Length; i++)
            _sdMonthHasData[i] = saved.Any(e => e.Month == _fyMonths[i]);
    }

    void SelectSdMonth(int month)
    {
        _sdMonth = month;
        _sdAnnual = null;
        if (_sdEmpId == 0) return;
        int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
        int yr = month >= 4 ? fyStart : fyStart + 1;
        _sdCurEntry = SalarySvc.Get(_sdEmpId, AppState.CurrentFY, month);
        MonthlySalaryEntry e;
        var seedEmp = _employees.FirstOrDefault(x => x.Id == _sdEmpId);
        var seedSs  = seedEmp?.Salary;
        if (_sdCurEntry != null)
        {
            // Saved entry is authoritative — use as-is (written by user save or Monthly Run sync)
            e = _sdCurEntry;
        }
        else
        {
            // No saved entry — seed from employee's salary structure
            e = new MonthlySalaryEntry
            {
                Basic            = seedSs?.Basic             ?? 0,
                HRA              = seedSs?.Hra               ?? 0,
                DaAmount         = seedSs?.Da                ?? 0,
                SpecialAllowance = seedSs?.SpecialAllowance  ?? 0,
                MedicalAllowance = seedSs?.MedicalAllowance  ?? 0,
                Lta              = seedSs?.Lta               ?? 0,
                OtherAllowances  = seedSs?.OtherAllowance    ?? 0,
                PfEmployee       = seedSs != null && (seedSs.PfFixedAmount > 0 || seedSs.PfApplicable)
                                   ? (seedSs.PfFixedAmount > 0 ? seedSs.PfFixedAmount : Math.Round(seedSs.Basic * 0.12))
                                   : 0,
                EsiEmployee      = seedSs != null && seedSs.EsiApplicable && seedSs.GrossSalary <= 21000
                                   ? Math.Round(seedSs.GrossSalary * 0.0075)
                                   : 0,
                ProfessionalTax  = seedSs != null
                                   ? PayrollService.GetPtPublic(seedSs.PtState, seedSs.GrossSalary)
                                   : 0,
            };
        }
        // populate fields
        _sdBasic = e.Basic; _sdGradePay = e.GradePay; _sdHra = e.HRA; _sdDaAmt = e.DaAmount;
        _sdSpecial = e.SpecialAllowance; _sdMedical = e.MedicalAllowance; _sdLta = e.Lta;
        _sdBonus = e.Bonus; _sdCommission = e.Commission; _sdAdvance = e.AdvanceSalary;
        _sdArrears = e.Arrears; _sdOther = e.OtherAllowances; _sdNpsEmployer = e.NpsEmployer;
        _sdPerqTotal = e.PerqTotal; _sdPerqExempted = e.PerqExempted;
        _sdLeaveEnc = e.LeaveEncTotal; _sdLeaveEncEx = e.LeaveEncExempted;
        _sdPf = e.PfEmployee; _sdVpf = e.VPF; _sdPt = e.ProfessionalTax;
        _sdEsi = e.EsiEmployee; _sdTds = e.TdsDeducted;
        _sdVarEarnRows = new();
        _sdVarDedRows  = new();
    }

    MonthlySalaryEntry BuildSdEntry()
    {
        int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
        int yr = _sdMonth >= 4 ? fyStart : fyStart + 1;
        var emp = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();
        return new MonthlySalaryEntry
        {
            Id = _sdCurEntry?.Id ?? 0,
            EmployeeId = _sdEmpId, DeductorId = AppState.CurrentDeductorId, EmployeeName = emp.Name, Pan = emp.Pan,
            Month = _sdMonth, Year = yr, FinancialYear = AppState.CurrentFY,
            Basic = _sdBasic, GradePay = _sdGradePay, HRA = _sdHra, DaAmount = _sdDaAmt,
            SpecialAllowance = _sdSpecial, MedicalAllowance = _sdMedical, Lta = _sdLta,
            Bonus = _sdBonus, Commission = _sdCommission, AdvanceSalary = _sdAdvance,
            Arrears = _sdArrears, OtherAllowances = _sdOther, NpsEmployer = _sdNpsEmployer,
            PerqTotal = _sdPerqTotal, PerqExempted = _sdPerqExempted,
            LeaveEncTotal = _sdLeaveEnc, LeaveEncExempted = _sdLeaveEncEx,
            PfEmployee = _sdPf, VPF = _sdVpf, ProfessionalTax = _sdPt,
            EsiEmployee = _sdEsi, TdsDeducted = _sdTds, TaxComputed = _sdTds,
        };
    }

    async Task SdCompute()
    {
        if (_sdEmpId == 0) { Snackbar.Add("Select an employee first.", Severity.Warning); return; }
        if (_sdMonth == 0) { Snackbar.Add("Select a month first.", Severity.Warning); return; }
        _sdComputing = true;
        StateHasChanged();
        try
        {
            var entry = BuildSdEntry();
            var emp   = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();
            var decl  = PayrollSvc.GetDeclaration(_sdEmpId, AppState.CurrentFY)
                        ?? new TaxDeclaration { EmployeeId = _sdEmpId, FinancialYear = AppState.CurrentFY };
            _sdAnnual = await Task.Run(() => SalarySvc.ComputeMonth(entry, emp, AppState.CurrentFY, decl));
            _sdTds    = _sdAnnual.ThisMonthTds;
        }
        catch (Exception ex) { Snackbar.Add("Compute error: " + ex.Message, Severity.Error); }
        _sdComputing = false;
        StateHasChanged();
    }

    void SdSaveMonth()
    {
        if (_sdEmpId == 0) { Snackbar.Add("Select an employee first.", Severity.Warning); return; }
        if (_sdMonth == 0) { Snackbar.Add("Select a month first.", Severity.Warning); return; }
        try
        {
            var entry = BuildSdEntry();
            entry.RecalcGross();
            SalarySvc.Save(entry);
            _sdCurEntry = entry;
            RefreshSdMonthStrip();
            StateHasChanged();
            Snackbar.Add($"Saved {new DateTime(1, _sdMonth, 1):MMMM} salary for {entry.EmployeeName}.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Save error: " + ex.Message, Severity.Error); }
    }

    async Task SdCopyToAll()
    {
        if (_sdEmpId == 0) { Snackbar.Add("Select an employee first.", Severity.Warning); return; }
        var confirmed = await DialogSvc.ShowMessageBox(
            "Copy to All Months?",
            $"Copy {new DateTime(1, _sdMonth, 1):MMMM} salary to all 12 months and compute TDS for each? Existing entries will be overwritten.",
            yesText: "Yes, Copy All", cancelText: "Cancel");
        if (confirmed != true) return;

        _sdComputing = true;
        try
        {
            var base_ = BuildSdEntry();
            var emp   = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();
            var decl  = PayrollSvc.GetDeclaration(_sdEmpId, AppState.CurrentFY)
                        ?? new TaxDeclaration { EmployeeId = _sdEmpId, FinancialYear = AppState.CurrentFY };
            int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
            int saved = 0;

            await Task.Run(() =>
            {
                foreach (int m in _fyMonths)
                {
                    int yr = m >= 4 ? fyStart : fyStart + 1;
                    var copy = new MonthlySalaryEntry
                    {
                        Id = 0, EmployeeId = base_.EmployeeId, EmployeeName = base_.EmployeeName,
                        Pan = base_.Pan, Month = m, Year = yr, FinancialYear = base_.FinancialYear,
                        Basic = base_.Basic, GradePay = base_.GradePay, HRA = base_.HRA, DaAmount = base_.DaAmount,
                        SpecialAllowance = base_.SpecialAllowance, MedicalAllowance = base_.MedicalAllowance, Lta = base_.Lta,
                        Bonus = base_.Bonus, Commission = base_.Commission, AdvanceSalary = base_.AdvanceSalary,
                        Arrears = base_.Arrears, OtherAllowances = base_.OtherAllowances, NpsEmployer = base_.NpsEmployer,
                        PerqTotal = base_.PerqTotal, PerqExempted = base_.PerqExempted,
                        LeaveEncTotal = base_.LeaveEncTotal, LeaveEncExempted = base_.LeaveEncExempted,
                        PfEmployee = base_.PfEmployee, VPF = base_.VPF, ProfessionalTax = base_.ProfessionalTax,
                        EsiEmployee = base_.EsiEmployee,
                    };
                    try
                    {
                        var annual = SalarySvc.ComputeMonth(copy, emp, AppState.CurrentFY, decl);
                        copy.TdsDeducted = annual.ThisMonthTds;
                        copy.TaxComputed = annual.ThisMonthTds;
                    }
                    catch { }
                    copy.RecalcGross();
                    SalarySvc.Save(copy);
                    saved++;
                }
            });

            RefreshSdMonthStrip();
            SelectSdMonth(_sdMonth);
            Snackbar.Add($"Copied and computed TDS for all {saved} months.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ex.Message, Severity.Error); }
        _sdComputing = false;
    }


    void OnRunMonthChanged(int month)
    {
        _runMonth = month;
        // Rebuild pro-rata grid: flag employees who joined mid-month
        int fyStart = 0;
        if (AppState.CurrentFY.Length >= 4) int.TryParse(AppState.CurrentFY[..4], out fyStart);
        int yr = _runMonth >= 4 ? fyStart : fyStart + 1;
        if (yr == 0) yr = _runYear;
        var monthStart = new DateTime(yr == 0 ? _runYear : yr, month, 1);
        var monthEnd   = new DateTime(yr == 0 ? _runYear : yr, month, DateTime.DaysInMonth(yr == 0 ? _runYear : yr, month));

        _proRataRows = _employees.Where(e => e.IsActive)
            .Select(e => {
                DateTime.TryParse(e.JoinDate, out var jd);
                bool isMidMonthJoiner = !string.IsNullOrEmpty(e.JoinDate) && jd >= monthStart && jd <= monthEnd;
                return new ProRataRow
                {
                    EmpId    = e.Id,
                    Name     = e.Name,
                    Code     = e.EmployeeCode,
                    Pan      = e.Pan,
                    JoinDate = e.JoinDate ?? "",
                    // Pre-fill days for mid-month joiners; others default to null (full month)
                    DaysWorked = isMidMonthJoiner ? (int?)(monthEnd - jd).Days + 1 : null
                };
            })
            .ToList();
    }

    async Task RunBulkPayroll()
    {
        _runError   = "";
        _running    = true;
        _runResults = new();
        await Task.Yield();
        try
        {
            var overrides = _proRataRows
                .Where(r => r.DaysWorked.HasValue)
                .ToDictionary(r => r.EmpId, r => r.DaysWorked!.Value);
            _runResults = PayrollSvc.RunBulk(
                AppState.CurrentDeductorId, _runMonth, _runYear,
                AppState.CurrentFY, overrides.Count > 0 ? overrides : null);
        }
        catch (Exception ex) { _runError = ex.Message; }
        _running = false;

        // Immediately sync computed results to Salary Data so the tab reflects the run
        foreach (var r in _runResults)
        {
            try { SyncRunToSalaryEntry(r.Run); } catch { }
        }

        // Refresh Salary Data tab if it's already showing one of the computed employees/month
        if (_sdEmpId > 0 && _sdMonth > 0
            && _runResults.Any(r => r.Run.EmployeeId == _sdEmpId && r.Run.Month == _runMonth))
        {
            SelectSdMonth(_sdMonth);
            RefreshSdMonthStrip();
        }
    }

    void SaveRun()
    {
        foreach (var r in _runResults)
        {
            r.Run.Status = "Processed";
            PayrollSvc.SaveRun(r.Run);
            SyncRunToSalaryEntry(r.Run);
        }
        Snackbar.Add($"Saved {_runResults.Count} payroll records as Processed.", Severity.Success);

        // Refresh Salary Data tab if it's showing one of the just-saved employees/month
        if (_sdEmpId > 0 && _sdMonth > 0
            && _runResults.Any(r => r.Run.EmployeeId == _sdEmpId && r.Run.Month == _runMonth))
        {
            SelectSdMonth(_sdMonth);
            RefreshSdMonthStrip();
        }
    }

    // Monthly Run is authoritative — always overwrites earnings + deductions in DB and in UI fields.
    void SyncRunToSalaryEntry(PayrollRun run)
    {
        try
        {
            int fyStart = TaxRules.FyStartYear(run.FinancialYear);
            int yr = run.Month >= 4 ? fyStart : fyStart + 1;

            var existing = SalarySvc.Get(run.EmployeeId, run.FinancialYear, run.Month);
            var entry = existing ?? new MonthlySalaryEntry();

            entry.EmployeeId      = run.EmployeeId;
            entry.DeductorId      = run.DeductorId;
            entry.FinancialYear   = run.FinancialYear;
            entry.Month           = run.Month;
            entry.Year            = yr;

            entry.Basic            = run.Basic;
            entry.HRA              = run.Hra;
            entry.DaAmount         = run.Da;
            entry.SpecialAllowance = run.Special;
            entry.MedicalAllowance = run.Medical;
            entry.Lta              = run.Lta;
            entry.OtherAllowances  = run.Other;
            entry.PfEmployee       = run.PfEmployee;
            entry.EsiEmployee      = run.EsiEmployee;
            entry.ProfessionalTax  = run.ProfessionalTax;
            entry.TdsDeducted      = run.TdsDeducted;

            entry.RecalcGross();
            SalarySvc.Save(entry);

            // If this run matches the currently displayed Salary Data entry, update UI fields live
            if (run.EmployeeId == _sdEmpId && run.Month == _sdMonth)
                ApplyRunToSdFields(run);
        }
        catch (Exception ex) { Snackbar.Add("Salary sync error: " + ex.Message, Severity.Error); }
    }

    // Update Salary Data UI fields directly from a run result (no DB round-trip needed)
    void ApplyRunToSdFields(PayrollRun run)
    {
        _sdBasic   = run.Basic;
        _sdHra     = run.Hra;
        _sdDaAmt   = run.Da;
        _sdSpecial = run.Special;
        _sdMedical = run.Medical;
        _sdLta     = run.Lta;
        _sdOther   = run.Other;
        _sdPf      = run.PfEmployee;
        _sdEsi     = run.EsiEmployee;
        _sdPt      = run.ProfessionalTax;
        _sdTds     = run.TdsDeducted;
    }

    void PushTo24Q()
    {
        try
        {
            // Auto-save runs first so they get IDs (required for MarkAsPushed)
            foreach (var r in _runResults.Where(r => r.Run.Id == 0))
            {
                r.Run.Status = "Processed";
                PayrollSvc.SaveRun(r.Run);
                SyncRunToSalaryEntry(r.Run);
            }
            var runs = _runResults.Select(r => r.Run).ToList();
            int pushed = PayrollSvc.PushTo24Q(runs, AppState.CurrentDeductorId);
            if (pushed > 0)
                Snackbar.Add($"Pushed {pushed} entr{(pushed == 1 ? "y" : "ies")} to 24Q.", Severity.Success);
            else
                Snackbar.Add("Nothing new to push — all runs already pushed or TDS is zero.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Push failed: " + ex.Message, Severity.Error);
        }
    }

    void ExportRunExcel()
    {
        try
        {
            using var wb = new ClosedXML.Excel.XLWorkbook();
            var ws = wb.Worksheets.Add("Payroll Run");
            var headers = new[] {
                "Code","Employee","PAN","Gross","HRA Exempt","PF","ESI","PT",
                "Taxable Income","Annual Tax","Surcharge+Cess","YTD TDS","TDS This Month","Net Pay",
                "Regime","Old Regime Tax","New Regime Tax","Status"
            };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#1a55a0");
                ws.Cell(1, i + 1).Style.Font.FontColor = ClosedXML.Excel.XLColor.White;
            }
            int row = 2;
            foreach (var r in _runResults)
            {
                var run = r.Run;
                ws.Cell(row, 1).Value  = run.EmployeeCode;
                ws.Cell(row, 2).Value  = run.EmployeeName;
                ws.Cell(row, 3).Value  = run.Pan;
                ws.Cell(row, 4).Value  = run.GrossSalary;
                ws.Cell(row, 5).Value  = run.HraExemption;
                ws.Cell(row, 6).Value  = run.PfEmployee;
                ws.Cell(row, 7).Value  = run.EsiEmployee;
                ws.Cell(row, 8).Value  = run.ProfessionalTax;
                ws.Cell(row, 9).Value  = run.TaxableIncome;
                ws.Cell(row, 10).Value = run.AnnualTax;
                ws.Cell(row, 11).Value = run.Surcharge + run.Cess;
                ws.Cell(row, 12).Value = run.YtdTds;
                ws.Cell(row, 13).Value = run.TdsDeducted;
                ws.Cell(row, 14).Value = run.NetPay;
                ws.Cell(row, 15).Value = run.TaxRegimeUsed;
                ws.Cell(row, 16).Value = r.TaxOldRegime;
                ws.Cell(row, 17).Value = r.TaxNewRegime;
                ws.Cell(row, 18).Value = run.Status;
                row++;
            }
            ws.Columns().AdjustToContents();

            var folder = FolderManager.PayrollRunsFolder;
            Directory.CreateDirectory(folder);
            var month = new DateTime(1, _runMonth, 1).ToString("MMM");
            var path = Path.Combine(folder, $"PayrollRun_{month}{_runYear}_{AppState.CurrentFY.Replace("/","-")}.xlsx");
            wb.SaveAs(path);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Exported: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Export failed: " + ex.Message, Severity.Error); }
    }

    void LoadSavedRuns()
    {
        _savedRuns  = PayrollSvc.GetRuns(_slipMonth, _slipYear, AppState.CurrentDeductorId);
        _slipLoaded = true;
    }

    void LoadYearSummary()
    {
        _yearSummaries = PayrollSvc.GetYearSummary(AppState.CurrentFY, AppState.CurrentDeductorId);
    }

    async Task DownloadFullYearZip()
    {
        _zipping = true;
        try
        {
            var allRuns = await Task.Run(() =>
                PayrollSvc.GetRunsForFY(AppState.CurrentFY, AppState.CurrentDeductorId));
            if (!allRuns.Any()) { Snackbar.Add("No runs found for this FY.", Severity.Warning); _zipping = false; return; }

            var folder = Path.Combine(FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY), "AllSlips");
            Directory.CreateDirectory(folder);

            var ded = DeductorSvc.GetAll().FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();
            var emps = PayrollSvc.GetEmployees(AppState.CurrentDeductorId);

            await Task.Run(() =>
            {
                foreach (var run in allRuns)
                {
                    try
                    {
                        var emp = emps.FirstOrDefault(e => e.Id == run.EmployeeId)
                                  ?? new Employee { Id = run.EmployeeId, EmployeeCode = run.EmployeeCode, Name = run.EmployeeName, Pan = run.Pan, TaxRegime = run.TaxRegimeUsed };
                        var entry = SalarySvc.Get(run.EmployeeId, run.FinancialYear, run.Month)
                                    ?? BuildEntryFromRun(run);
                        AnnualComputation annual;
                        try
                        {
                            var decl = PayrollSvc.GetDeclaration(emp.Id, run.FinancialYear)
                                       ?? new TDSPro.DAL.Models.TaxDeclaration { EmployeeId = emp.Id, FinancialYear = run.FinancialYear };
                            annual = SalarySvc.ComputeMonth(entry, emp, run.FinancialYear, decl);
                        }
                        catch { annual = BuildAnnualFromRun(run); }
                        SalarySlipExport.GenerateHtml(entry, annual, emp, ded, folder);
                    }
                    catch { }
                }
            });

            var zipPath = Path.Combine(FolderManager.SalarySlipsFolder,
                $"AllSlips_{AppState.CurrentFY.Replace("/","-")}.zip");
            if (File.Exists(zipPath)) File.Delete(zipPath);
            ZipFile.CreateFromDirectory(folder, zipPath);
            FolderManager.OpenFolder(Path.GetDirectoryName(zipPath)!);
            Snackbar.Add($"ZIP created: {Path.GetFileName(zipPath)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ex.Message, Severity.Error); }
        _zipping = false;
    }


@page "/activate"
@inject AppStateService AppState
@inject LicenseService LicenseSvc
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudText Typo="Typo.h5" Class="mb-4">License Activation</MudText>

<MudGrid>
    @* ── CURRENT STATUS ── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Current License</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIcon Icon="@(AppState.CurrentLicense.IsValid && !AppState.CurrentLicense.IsExpired
                                      ? Icons.Material.Filled.Verified
                                      : Icons.Material.Filled.Warning)"
                             Color="@(AppState.CurrentLicense.IsValid && !AppState.CurrentLicense.IsExpired
                                       ? Color.Success : Color.Warning)" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudSimpleTable Dense="true">
                    <tbody>
                        <tr>
                            <td><b>Type</b></td>
                            <td>@AppState.CurrentLicense.TierLabel</td>
                        </tr>
                        <tr>
                            <td><b>Status</b></td>
                            <td>
                                @if (AppState.CurrentLicense.IsExpired)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Expired</MudChip>
                                }
                                else if (AppState.CurrentLicense.IsTrial)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Trial</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><b>Expires</b></td>
                            <td>@AppState.CurrentLicense.ExpiryDate.ToString("dd-MMM-yyyy")
                                (@AppState.CurrentLicense.DaysLeft days remaining)</td>
                        </tr>
                        <tr>
                            <td><b>Max Deductors</b></td>
                            <td>@(AppState.CurrentLicense.MaxDeductors == int.MaxValue ? "Unlimited" : AppState.CurrentLicense.MaxDeductors.ToString())</td>
                        </tr>
                        <tr>
                            <td><b>Max Entries</b></td>
                            <td>@(AppState.CurrentLicense.MaxEntries == int.MaxValue ? "Unlimited" : AppState.CurrentLicense.MaxEntries.ToString())</td>
                        </tr>
                        <tr>
                            <td><b>Max Users</b></td>
                            <td>@(AppState.CurrentLicense.MaxUsers == int.MaxValue ? "Unlimited" : AppState.CurrentLicense.MaxUsers.ToString())</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* ── MACHINE ID ── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Your Machine ID</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    To get a <strong>Pro license key</strong>, email your Machine ID to
                    <strong>admin@capitaldesk.co.in</strong>. Your key will be locked to this machine.
                </MudAlert>
                <div class="d-flex align-center gap-2">
                    <MudTextField Value="@_machineId" Label="Machine ID" Variant="Variant.Outlined"
                                  ReadOnly="true" Style="font-family:monospace;font-size:16px;font-weight:700;letter-spacing:2px" />
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                   Color="Color.Primary" OnClick="CopyMachineId" />
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-2"
                           StartIcon="@Icons.Material.Filled.Email" OnClick="EmailForKey">
                    Email for Pro Key
                </MudButton>
            </MudCardContent>
        </MudCard>

        @* ── ACTIVATE ── *@
        <MudCard Elevation="2" Class="mt-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Enter License Key</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_licenseKey" Label="License Key"
                              Variant="Variant.Outlined" Class="mb-3"
                              Style="font-family:monospace"
                              Placeholder="XXXX-XXXX-XXXX-XXXX-XXXX-XXXX-XXXX-XXXX" />

                @if (!string.IsNullOrEmpty(_activationMsg))
                {
                    <MudAlert Severity="@_alertSeverity" Class="mb-2">@_activationMsg</MudAlert>
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="ActivateKey" Disabled="_activating">
                    @if (_activating) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Activate
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* ── TIER COMPARISON ── *@
    <MudItem xs="12">
        <MudCard Elevation="1" Class="mt-2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">License Tiers</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudSimpleTable Dense="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Feature</th>
                            <th>Trial</th>
                            <th>Pro</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>All Features (FVU, Form 16, Payroll, Reports…)</td><td>✅</td><td>✅</td></tr>
                        <tr><td>Deductors</td><td>1</td><td>As per your plan</td></tr>
                        <tr><td>TDS Entries</td><td>25</td><td>As per your plan</td></tr>
                        <tr><td>Users</td><td>1</td><td>As per your plan</td></tr>
                        <tr><td>Machine-locked key</td><td>❌</td><td>✅</td></tr>
                        <tr><td>Validity</td><td>30 days from install</td><td>As per your plan</td></tr>
                        <tr><td>Read-only after expiry</td><td>✅</td><td>✅</td></tr>
                    </tbody>
                </MudSimpleTable>
                <MudAlert Severity="Severity.Success" Dense="true" Class="mt-3">
                    Pro limits (deductors, entries, users, validity) are agreed at purchase and locked into your license key.
                    Email <strong>admin@capitaldesk.co.in</strong> with your Machine ID above to get a Pro key.
                </MudAlert>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _machineId    = "";
    private string _licenseKey   = "";
    private string _activationMsg = "";
    private bool   _activating;
    private Severity _alertSeverity = Severity.Info;

    protected override void OnInitialized()
    {
        _machineId = LicenseService.GetMachineId();
    }

    async Task ActivateKey()
    {
        if (string.IsNullOrWhiteSpace(_licenseKey))
        {
            _activationMsg  = "Please enter a license key.";
            _alertSeverity  = Severity.Warning;
            return;
        }
        _activating    = true;
        _activationMsg = "";
        await Task.Yield();

        try
        {
            var result = LicenseSvc.ValidateKey(_licenseKey.Trim());
            if (result.IsValid)
            {
                AppState.CurrentLicense = result;
                _activationMsg  = $"License activated! {result.TierLabel} — valid until {result.ExpiryDate:dd-MMM-yyyy}.";
                _alertSeverity  = Severity.Success;
                Snackbar.Add("License activated successfully.", Severity.Success);
                _licenseKey = "";
            }
            else
            {
                _activationMsg = result.Message;
                _alertSeverity = Severity.Error;
            }
        }
        catch (Exception ex)
        {
            _activationMsg = "Activation error: " + ex.Message;
            _alertSeverity = Severity.Error;
        }
        _activating = false;
    }

async Task CopyMachineId()
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>("window.tdspro.copyToClipboard", _machineId);
            if (!ok) throw new Exception();
        }
        catch
        {
            System.Windows.Application.Current.Dispatcher.Invoke(() =>
                System.Windows.Clipboard.SetText(_machineId));
        }
        Snackbar.Add("Machine ID copied to clipboard.", Severity.Success);
    }

    void EmailForKey()
    {
        var subject = Uri.EscapeDataString("TDS Pro — Request Pro License Key");
        var body    = Uri.EscapeDataString(
            $"Hello,\n\nI would like to purchase a Pro license for TDS Pro.\n\n" +
            $"Machine ID : {_machineId}\n" +
            $"User       : {AppState.CurrentUser}\n\n" +
            $"Please send me pricing and a license key.\n\nRegards");
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(
                $"mailto:admin@capitaldesk.co.in?subject={subject}&body={body}")
                { UseShellExecute = true });
        }
        catch { Snackbar.Add("Please email admin@capitaldesk.co.in with your Machine ID.", Severity.Info); }
    }
}

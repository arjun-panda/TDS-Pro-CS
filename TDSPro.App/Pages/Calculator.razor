@page "/calculator"
@inject ISnackbar Snackbar
@using TDSPro.Common

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">TDS Interest & Late Fee Calculator</MudText>
</div>

<MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
    <b>u/s 234A</b>: 1% per month on TDS amount for delay in deduction. &nbsp;
    <b>u/s 234B</b>: 1.5% per month on TDS amount for delay in deposit to government. &nbsp;
    <b>u/s 234E</b>: ₹200/day for late filing of TDS return (max = TDS amount). &nbsp;
    Part of a month is counted as a full month for interest.
</MudAlert>

<MudGrid Spacing="3">
    @* ── Input Panel ── *@
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-5" Elevation="2" Style="border-radius:12px">
            <MudText Typo="Typo.subtitle1" Class="mb-4">Enter Details</MudText>

            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">TDS Details</MudText>
            <MudNumericField @bind-Value="_tdsAmount" Label="TDS Amount (₹)*" Variant="Variant.Outlined"
                             Format="N2" Min="0" Class="mb-3 amount-field" HideSpinButtons="true"
                             HelperText="Amount of TDS that was/is payable" />
            <DateField Value="_deductDate" ValueChanged="d => _deductDate = d" Label="Date of Deduction*"
                       Variant="Variant.Outlined" Class="date-field mb-3" />
            <DateField Value="_payDate" ValueChanged="d => _payDate = d" Label="Date of Deposit to Govt*"
                       Variant="Variant.Outlined" Class="date-field mb-3" />

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Late Filing Fee (u/s 234E)</MudText>
            <DateField Value="_dueDate" ValueChanged="d => _dueDate = d" Label="Return Due Date"
                       Variant="Variant.Outlined" Class="date-field mb-3" />
            <DateField Value="_fileDate" ValueChanged="d => _fileDate = d" Label="Actual Filing Date"
                       Variant="Variant.Outlined" Class="date-field mb-3" />

            <div class="d-flex gap-2 mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Calculate"
                           OnClick="Calculate">Calculate</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="Clear">Clear</MudButton>
            </div>

            @if (!string.IsNullOrEmpty(_errorMsg))
            { <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_errorMsg</MudAlert> }
        </MudPaper>
    </MudItem>

    @* ── Result Panel ── *@
    <MudItem xs="12" md="7">
        @if (_calculated)
        {
            <MudPaper Class="pa-5" Elevation="2" Style="border-radius:12px;border-top:4px solid #1565C0">
                <MudText Typo="Typo.subtitle1" Class="mb-4">Calculation Result</MudText>

                <MudSimpleTable Dense="true" Hover="false">
                    <tbody>
                        <tr>
                            <td style="width:60%;color:#666">TDS Amount</td>
                            <td style="text-align:right;font-weight:600">₹@_tdsAmount.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td style="color:#666">Date of Deduction</td>
                            <td style="text-align:right">@_deductDate?.ToString("dd-MMM-yyyy")</td>
                        </tr>
                        <tr>
                            <td style="color:#666">Date of Deposit</td>
                            <td style="text-align:right">@_payDate?.ToString("dd-MMM-yyyy")</td>
                        </tr>
                        <tr style="background:#fff8e1">
                            <td style="color:#666">
                                Interest u/s 234A (1%/month — delay in deduction)<br/>
                                <span style="font-size:10px">@_deductMonths month(s) × 1% × ₹@_tdsAmount.ToString("N0")</span>
                            </td>
                            <td style="text-align:right;color:#e65100;font-weight:700">₹@_interest234A.ToString("N2")</td>
                        </tr>
                        <tr style="background:#fff3e0">
                            <td style="color:#666">
                                Interest u/s 234B (1.5%/month — delay in deposit)<br/>
                                <span style="font-size:10px">@_depositMonths month(s) × 1.5% × ₹@_tdsAmount.ToString("N0")</span>
                            </td>
                            <td style="text-align:right;color:#e65100;font-weight:700">₹@_interest234B.ToString("N2")</td>
                        </tr>
                        @if (_lateFee234E > 0)
                        {
                            <tr style="background:#fce4ec">
                                <td style="color:#666">
                                    Late Fee u/s 234E (₹200/day, max = TDS)<br/>
                                    <span style="font-size:10px">@_lateFileDays day(s) × ₹200, capped at ₹@_tdsAmount.ToString("N0")</span>
                                </td>
                                <td style="text-align:right;color:#c62828;font-weight:700">₹@_lateFee234E.ToString("N2")</td>
                            </tr>
                        }
                        <tr style="background:#e3f2fd">
                            <td style="font-weight:700;font-size:15px">TOTAL PAYABLE</td>
                            <td style="text-align:right;font-weight:700;font-size:20px;color:#1565C0">
                                ₹@(_tdsAmount + _interest234A + _interest234B + _lateFee234E).ToString("N2")
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>

                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                    This is an estimate. Actual liability may differ based on AO orders, grace days, and circular exceptions.
                    Consult a CA for exact computation.
                </MudAlert>
            </MudPaper>

            @* Quick reference table *@
            <MudPaper Class="pa-4 mt-3" Elevation="1" Style="border-radius:10px">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Quick Reference — TDS Due Dates</MudText>
                <MudSimpleTable Dense="true">
                    <thead>
                        <tr>
                            <th>Quarter</th>
                            <th>Period</th>
                            <th>TDS Deposit Due</th>
                            <th>Return Filing Due</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Q1</td><td>Apr–Jun</td><td>7th of next month</td><td>31st July</td></tr>
                        <tr><td>Q2</td><td>Jul–Sep</td><td>7th of next month</td><td>31st October</td></tr>
                        <tr><td>Q3</td><td>Oct–Dec</td><td>7th of next month</td><td>31st January</td></tr>
                        <tr><td>Q4</td><td>Jan–Mar</td><td>30th April (Mar: 7th Apr)</td><td>31st May</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="pa-6 d-flex flex-column align-center justify-center" Elevation="1"
                      Style="border-radius:12px;min-height:300px;border:2px dashed #e0e0e0">
                <MudIcon Icon="@Icons.Material.Filled.Calculate" Style="font-size:64px;color:#e0e0e0" Class="mb-3" />
                <MudText Color="Color.Secondary">Enter TDS details and click Calculate</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                    Computes interest u/s 234A, 234B and late fee u/s 234E
                </MudText>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    private double    _tdsAmount  = 10000;
    private string    _errorMsg   = "";
    private bool      _calculated;

    private DateTime? _deductDate;
    private DateTime? _payDate;
    private DateTime? _dueDate;
    private DateTime? _fileDate;

    private double _interest234A;
    private double _interest234B;
    private double _lateFee234E;
    private int    _deductMonths;
    private int    _depositMonths;
    private int    _lateFileDays;

    protected override void OnInitialized()
    {
        _deductDate = DateTime.Today.AddMonths(-2);
        _payDate    = DateTime.Today;
    }

    void Calculate()
    {
        _errorMsg = ""; _calculated = false;

        if (_tdsAmount <= 0)     { _errorMsg = "TDS Amount must be greater than zero."; return; }
        if (_deductDate == null) { _errorMsg = "Date of Deduction is required."; return; }
        if (_payDate == null)    { _errorMsg = "Date of Deposit is required."; return; }
        if (_payDate < _deductDate) { _errorMsg = "Date of Deposit cannot be before Date of Deduction."; return; }

        // 234A: 1% per month — from deduction date to payment date (deduction delay)
        _deductMonths  = MonthDiff(_deductDate.Value, _payDate.Value);
        _interest234A  = Math.Round(_tdsAmount * 0.01 * _deductMonths, 2);

        // 234B: 1.5% per month — from deduction date to deposit date
        _depositMonths = _deductMonths;
        _interest234B  = Math.Round(_tdsAmount * 0.015 * _depositMonths, 2);

        // 234E: ₹200/day for late filing
        _lateFee234E = 0; _lateFileDays = 0;
        if (_dueDate.HasValue && _fileDate.HasValue && _fileDate > _dueDate)
        {
            _lateFileDays = (int)(_fileDate.Value - _dueDate.Value).TotalDays;
            _lateFee234E  = Math.Min(_lateFileDays * 200.0, _tdsAmount);
        }

        _calculated = true;
    }

    void Clear()
    {
        _tdsAmount  = 10000;
        _deductDate = DateTime.Today.AddMonths(-2);
        _payDate    = DateTime.Today;
        _dueDate    = null; _fileDate = null;
        _errorMsg   = ""; _calculated = false;
    }

    static int MonthDiff(DateTime from, DateTime to)
    {
        int months = (to.Year - from.Year) * 12 + to.Month - from.Month;
        if (to.Day > from.Day) months++;
        return Math.Max(1, months);
    }
}

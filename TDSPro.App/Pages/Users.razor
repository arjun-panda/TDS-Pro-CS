@page "/users"
@inject AppStateService AppState
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<MudText Typo="Typo.h5" Class="mb-4">User Management</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenAdd" Class="mb-4">Add User</MudButton>

<div style="height:calc(100vh - 190px);overflow:hidden">
<MudDataGrid T="AppUser" Items="_items" Hover="true" Striped="true" Dense="true"
             FixedHeader="true" Height="calc(100vh - 190px)">
    <Columns>
        <PropertyColumn Property="x => x.Username"  Title="Username" />
        <PropertyColumn Property="x => x.FullName"  Title="Full Name" />
        <PropertyColumn Property="x => x.Role"      Title="Role" />
        <PropertyColumn Property="x => x.Email"     Title="Email" />
        <PropertyColumn Property="x => x.Status"    Title="Status" />
        <TemplateColumn Title="Actions" Sortable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"      Size="Size.Small" OnClick="() => OpenEdit(context.Item)" />
                <MudIconButton Icon="@Icons.Material.Filled.LockReset" Size="Size.Small" Color="Color.Warning"
                               OnClick="() => OpenResetPassword(context.Item)" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>
</div>

<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>@(_editing?.Id == 0 ? "Add" : "Edit") User</TitleContent>
    <DialogContent>
        @if (_editing != null)
        {
            <MudGrid>
                <MudItem xs="6"><MudTextField @bind-Value="_editing.Username" Label="Username*" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_editing.FullName" Label="Full Name" Variant="Variant.Outlined" /></MudItem>
                @if (_editing.Id == 0)
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_newPassword" Label="Password*" InputType="InputType.Password" Variant="Variant.Outlined" />
                    </MudItem>
                }
                <MudItem xs="6">
                    <MudSelect @bind-Value="_editing.Role" Label="Role" Variant="Variant.Outlined">
                        @foreach (var r in AppConstants.UserRoles)
                        { <MudSelectItem Value="@r">@r</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect @bind-Value="_editing.Status" Label="Status" Variant="Variant.Outlined">
                        <MudSelectItem Value='"Active"'>Active</MudSelectItem>
                        <MudSelectItem Value='"Inactive"'>Inactive</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12"><MudTextField Value="@_editing.Email" Label="Email" Variant="Variant.Outlined"
                                               InputType="InputType.Email" Style="text-transform:lowercase"
                                               Immediate="true" ValueChanged="@((string v) => _editing.Email = (v ?? "").Trim().ToLower())" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@* ── Reset Password Dialog ── *@
<MudDialog @bind-Visible="_resetDialogOpen" Options='new DialogOptions { MaxWidth=MaxWidth.Small, FullWidth=true }'>
    <TitleContent>Reset Password — @_resetUser?.Username</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_resetPassword" Label="New Password*" InputType="InputType.Password"
                      Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _resetDialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="DoResetPassword">Reset</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<AppUser> _items = new();
    private bool _dialogOpen;
    private AppUser? _editing;
    private string _newPassword = "";
    private bool _resetDialogOpen;
    private AppUser? _resetUser;
    private string _resetPassword = "";
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override void OnInitialized() => Load();

    void Load()
    {
        _items.Clear();
        try
        {
            using var conn = Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = "SELECT id, username, full_name, role, email, status FROM users ORDER BY username";
            using var rd = cmd.ExecuteReader();
            while (rd.Read())
                _items.Add(new AppUser
                {
                    Id = (int)(long)rd[0], Username = rd.GetString(1),
                    FullName = rd.IsDBNull(2) ? "" : rd.GetString(2),
                    Role     = rd.GetString(3),
                    Email    = rd.IsDBNull(4) ? "" : rd.GetString(4),
                    Status   = rd.GetString(5)
                });
        }
        catch (Exception ex) { Snackbar.Add("Failed to load users: " + ex.Message, Severity.Error); }
    }

    void OpenAdd()
    {
        _editing = new AppUser { Status = "Active", Role = "Operator" };
        _newPassword = ""; _dialogOpen = true;
    }

    void OpenEdit(AppUser u)
    {
        _editing = new AppUser { Id = u.Id, Username = u.Username, FullName = u.FullName, Role = u.Role, Email = u.Email, Status = u.Status };
        _dialogOpen = true;
    }

    void OpenResetPassword(AppUser u)
    {
        _resetUser = u; _resetPassword = ""; _resetDialogOpen = true;
    }

    void DoResetPassword()
    {
        if (_resetUser == null) return;
        if (string.IsNullOrWhiteSpace(_resetPassword) || _resetPassword.Length < 6)
        { Snackbar.Add("Password must be at least 6 characters.", Severity.Warning); return; }
        try
        {
            using var conn = Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = "UPDATE users SET password=@p WHERE id=@id";
            cmd.Parameters.AddWithValue("@p",  Database.HashPassword(_resetPassword));
            cmd.Parameters.AddWithValue("@id", _resetUser.Id);
            cmd.ExecuteNonQuery();
            _resetDialogOpen = false;
            Snackbar.Add($"Password reset for {_resetUser.Username}.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ex.Message, Severity.Error); }
    }

    void Save()
    {
        if (_editing == null) return;
        if (string.IsNullOrWhiteSpace(_editing.Username)) { Snackbar.Add("Username is required.", Severity.Warning); return; }
        if (_editing.Id == 0 && string.IsNullOrWhiteSpace(_newPassword)) { Snackbar.Add("Password is required for new users.", Severity.Warning); return; }
        if (_editing.Id == 0 && _newPassword.Length < 6) { Snackbar.Add("Password must be at least 6 characters.", Severity.Warning); return; }

        // License limit — only block when adding new user
        if (_editing.Id == 0)
        {
            if (AppState.CurrentLicense.IsReadOnly)
                { Snackbar.Add("License expired — renew to add users.", Severity.Warning); return; }
            if (_items.Count >= AppState.CurrentLicense.MaxUsers)
                { Snackbar.Add($"Limit reached: your license allows {AppState.CurrentLicense.MaxUsers} user(s). Upgrade to Pro for more.", Severity.Warning); return; }
        }

        try
        {
            using var conn = Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            if (_editing.Id == 0)
            {
                // Check for duplicate username
                using var chk = conn.CreateCommand();
                chk.CommandText = "SELECT COUNT(*) FROM users WHERE username=@u";
                chk.Parameters.AddWithValue("@u", _editing.Username.Trim());
                if ((long)chk.ExecuteScalar()! > 0) { Snackbar.Add("Username already exists.", Severity.Error); return; }

                var hash = Database.HashPassword(_newPassword);
                cmd.CommandText = "INSERT INTO users (username,password,full_name,role,email,status,created_at) VALUES (@u,@p,@fn,@r,@e,@s,@ca)";
                cmd.Parameters.AddWithValue("@u",  _editing.Username.Trim());
                cmd.Parameters.AddWithValue("@p",  hash);
                cmd.Parameters.AddWithValue("@fn", _editing.FullName);
                cmd.Parameters.AddWithValue("@r",  _editing.Role);
                cmd.Parameters.AddWithValue("@e",  _editing.Email);
                cmd.Parameters.AddWithValue("@s",  _editing.Status);
                cmd.Parameters.AddWithValue("@ca", DateTime.Now.ToString("o"));
            }
            else
            {
                cmd.CommandText = "UPDATE users SET username=@u, full_name=@fn, role=@r, email=@e, status=@s WHERE id=@id";
                cmd.Parameters.AddWithValue("@u",  _editing.Username.Trim());
                cmd.Parameters.AddWithValue("@fn", _editing.FullName);
                cmd.Parameters.AddWithValue("@r",  _editing.Role);
                cmd.Parameters.AddWithValue("@e",  _editing.Email);
                cmd.Parameters.AddWithValue("@s",  _editing.Status);
                cmd.Parameters.AddWithValue("@id", _editing.Id);
            }
            cmd.ExecuteNonQuery();
            _dialogOpen = false; Load();
            Snackbar.Add("Saved.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ex.Message, Severity.Error); }
    }

    public class AppUser
    {
        public int    Id       { get; set; }
        public string Username { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Role     { get; set; } = "";
        public string Email    { get; set; } = "";
        public string Status   { get; set; } = "Active";
    }
}

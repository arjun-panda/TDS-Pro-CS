@* Reusable KPI metric card used on Dashboard *@

<MudCard Elevation="2" Class="@_cardClass" @onclick="OnClick">
    <MudCardContent>
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Title</MudText>
                <MudText Typo="Typo.h5" Style="font-weight:700">@Value</MudText>
            </div>
            <MudIcon Icon="@Icon" Color="@Color" Size="Size.Large" />
        </div>
    </MudCardContent>
</MudCard>

<style>
    .kpi-card-clickable { cursor: pointer; transition: box-shadow 0.15s; }
    .kpi-card-clickable:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.18) !important; }
</style>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Icon  { get; set; } = "";
    [Parameter] public Color  Color { get; set; } = Color.Primary;
    [Parameter] public EventCallback OnClick { get; set; }

    private string _cardClass => OnClick.HasDelegate ? "kpi-card kpi-card-clickable" : "kpi-card";
}
